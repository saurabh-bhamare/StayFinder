<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Confirm & Pay</title>
  <link href="https://fonts.googleapis.com/css2?family=Cedarville+Cursive&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --pink: #FF385C;
      --pink-dark: #D93B55;
      --pink-soft: #3a1a1f;
      --text: #F0F0F0;
      --text-soft: #A0A0A0;
      --border: #2E2E2E;
      --bg: #0F0F0F;
      --white: #1A1A1A;
      --radius: 12px;
      --shadow-card: 0 6px 32px rgba(0,0,0,0.5);
      --shadow-hover: 0 12px 48px rgba(0,0,0,0.65);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* TOP BAR */
    .topbar {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 16px 32px;
      display: flex;
      align-items: center;
      gap: 10px;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .topbar-logo {
      font-family: 'Cedarville Cursive', cursive;
      font-size: 26px;
      color: var(--pink);
      letter-spacing: -0.5px;
      text-decoration: none;
    }

    .topbar-steps {
      margin-left: auto;
      display: flex;
      gap: 6px;
      align-items: center;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-soft);
    }

    .step { display: flex; align-items: center; gap: 6px; }
    .step-dot {
      width: 22px; height: 22px;
      border-radius: 50%;
      display: grid; place-items: center;
      font-size: 11px; font-weight: 700;
      background: var(--border);
      color: var(--text-soft);
    }
    .step.active .step-dot { background: var(--pink); color: white; }
    .step.active span { color: var(--text); }
    .step-line { width: 28px; height: 2px; background: var(--border); border-radius: 2px; }

    /* PAGE */
    .pg-wrap {
      max-width: 960px;
      margin: 0 auto;
      padding: 40px 24px 80px;
    }

    h2.page-title {
      font-size: 28px;
      font-weight: 600;
      letter-spacing: -0.5px;
      margin-bottom: 32px;
    }

    /* LAYOUT */
    .layout {
      display: grid;
      grid-template-columns: 1fr 400px;
      gap: 32px;
      align-items: start;
    }

    @media (max-width: 760px) {
      .layout { grid-template-columns: 1fr; }
      .sticky-card { position: static !important; }
    }

    /* LEFT — FORM */
    .form-section {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
    }

    .section-header {
      padding: 24px 28px 20px;
      border-bottom: 1px solid var(--border);
    }

    .section-header h3 {
      font-size: 18px;
      font-weight: 600;
    }

    .section-header p {
      font-size: 13.5px;
      color: var(--text-soft);
      margin-top: 4px;
    }

    .section-body {
      padding: 24px 28px;
    }

    /* DATE GRID */
    .date-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border: 1.5px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      transition: border-color 0.2s;
    }

    .date-grid:focus-within { border-color: var(--text); }

    .date-field {
      padding: 12px 16px;
      position: relative;
      cursor: pointer;
    }

    .date-field + .date-field {
      border-left: 1.5px solid var(--border);
    }

    .date-field label {
      display: block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text);
      margin-bottom: 4px;
    }

    .date-field input[type="date"] {
      border: none;
      outline: none;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 400;
      color: var(--text);
      background: transparent;
      cursor: pointer;
      width: 100%;
      color-scheme: dark;
    }

    .date-field input[type="date"]::-webkit-calendar-picker-indicator {
      opacity: 0.5;
      cursor: pointer;
    }

    /* GUESTS */
    .guests-row {
      margin-top: 16px;
      border: 1.5px solid var(--border);
      border-radius: 12px;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: border-color 0.2s;
    }

    .guests-row:focus-within { border-color: var(--text); }

    .guests-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .guests-control {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .guests-btn {
      width: 30px; height: 30px;
      border-radius: 50%;
      border: 1.5px solid var(--border);
      background: none;
      cursor: pointer;
      font-size: 18px;
      display: grid; place-items: center;
      color: var(--text-soft);
      transition: border-color 0.2s, color 0.2s;
      line-height: 1;
      padding-bottom: 2px;
    }

    .guests-btn:hover:not(:disabled) {
      border-color: var(--text);
      color: var(--text);
    }

    .guests-btn:disabled { opacity: 0.3; cursor: not-allowed; }

    #guestCount {
      font-size: 15px;
      font-weight: 500;
      min-width: 14px;
      text-align: center;
    }

    input[name="guests"] { display: none; }

    /* PRICE BREAKDOWN in form */
    .breakdown {
      margin-top: 20px;
      padding: 18px;
      background: #141414;
      border-radius: 10px;
      border: 1px solid var(--border);
      animation: fadeIn 0.3s ease;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; } }

    .breakdown-row {
      display: flex;
      justify-content: space-between;
      font-size: 14.5px;
      color: var(--text-soft);
      margin-bottom: 10px;
    }

    .breakdown-row.total {
      color: var(--text);
      font-weight: 600;
      font-size: 15.5px;
      border-top: 1px solid var(--border);
      padding-top: 12px;
      margin-bottom: 0;
    }

    /* CTA */
    .cta-wrap {
      padding: 0 28px 28px;
    }

    .btn-pay {
      width: 100%;
      background: linear-gradient(135deg, #FF385C 0%, #E31C5F 100%);
      color: white;
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      font-weight: 600;
      border: none;
      border-radius: 12px;
      padding: 16px;
      cursor: pointer;
      transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
      box-shadow: 0 4px 20px rgba(255,56,92,0.35);
      position: relative;
      overflow: hidden;
    }

    .btn-pay::after {
      content: '';
      position: absolute;
      inset: 0;
      background: white;
      opacity: 0;
      transition: opacity 0.15s;
    }

    .btn-pay:hover { transform: translateY(-1px); box-shadow: 0 8px 28px rgba(255,56,92,0.45); }
    .btn-pay:active { transform: translateY(0); }
    .btn-pay:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    .btn-pay.loading::after { opacity: 0.15; }

    .btn-pay .spinner {
      display: inline-block;
      width: 16px; height: 16px;
      border: 2px solid rgba(255,255,255,0.4);
      border-top-color: white;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      vertical-align: middle;
      margin-right: 8px;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .btn-note {
      text-align: center;
      font-size: 12.5px;
      color: var(--text-soft);
      margin-top: 12px;
    }

    /* RIGHT — STICKY CARD */
    .sticky-card {
      position: sticky;
      top: 80px;
    }

    .hotel-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: var(--shadow-card);
    }

    .hotel-img-wrap {
      position: relative;
      height: 200px;
      overflow: hidden;
    }

    .hotel-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }

    .hotel-card:hover .hotel-img-wrap img {
      transform: scale(1.04);
    }

    .hotel-badge {
      position: absolute;
      top: 12px;
      left: 12px;
      background: white;
      border-radius: 6px;
      padding: 4px 10px;
      font-size: 11.5px;
      font-weight: 600;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .hotel-badge span { color: var(--pink); font-size: 13px; }

    .hotel-info {
      padding: 18px 20px 20px;
    }

    .hotel-info h3 {
      font-size: 15.5px;
      font-weight: 600;
      line-height: 1.3;
      margin-bottom: 4px;
    }

    .hotel-location {
      font-size: 13px;
      color: var(--text-soft);
      display: flex;
      align-items: center;
      gap: 4px;
      margin-bottom: 14px;
    }

    .hotel-location svg { flex-shrink: 0; }

    .price-line {
      padding-top: 14px;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: baseline;
      gap: 6px;
    }

    .price-line .price {
      font-size: 19px;
      font-weight: 700;
    }

    .price-line .per-night {
      font-size: 13.5px;
      color: var(--text-soft);
    }

    /* RATING STARS */
    .stars {
      display: flex;
      gap: 2px;
      margin-bottom: 14px;
      align-items: center;
    }

    .stars svg { color: var(--pink); }
    .stars .rating-num { font-size: 13px; font-weight: 600; margin-left: 4px; }
    .stars .review-count { font-size: 12.5px; color: var(--text-soft); }

    /* TOAST */
    .toast {
      position: fixed;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: #222;
      color: white;
      padding: 14px 24px;
      border-radius: 50px;
      font-size: 14px;
      font-weight: 500;
      z-index: 999;
      transition: transform 0.35s cubic-bezier(.34,1.56,.64,1), opacity 0.3s;
      opacity: 0;
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
    .toast.success { background: #2E7D32; }
    .toast.error { background: #C62828; }

    /* DIVIDER */
    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 22px 0 18px;
      color: var(--text-soft);
      font-size: 12.5px;
    }

    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* SECURITY BADGES */
    .security-row {
      display: flex;
      gap: 16px;
      justify-content: center;
      margin-top: 16px;
    }

    .sec-badge {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 12px;
      color: var(--text-soft);
    }

    /* MODAL OVERLAY */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.55);
      z-index: 500;
      display: none;
      place-items: center;
      padding: 20px;
      backdrop-filter: blur(2px);
    }

    .modal-overlay.open { display: grid; }

    .modal {
      background: #1A1A1A;
      border-radius: 20px;
      padding: 36px;
      max-width: 420px;
      width: 100%;
      box-shadow: 0 24px 80px rgba(0,0,0,0.25);
      animation: modalIn 0.3s cubic-bezier(.34,1.56,.64,1);
      text-align: center;
    }

    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.88); }
      to { opacity: 1; transform: scale(1); }
    }

    .modal-icon {
      width: 64px; height: 64px;
      background: var(--pink-soft);
      border-radius: 50%;
      display: grid; place-items: center;
      margin: 0 auto 18px;
    }

    .modal h3 { font-size: 20px; font-weight: 700; margin-bottom: 8px; }
    .modal p { font-size: 14.5px; color: var(--text-soft); margin-bottom: 6px; }

    .modal-amount {
      font-size: 32px;
      font-weight: 700;
      color: var(--text);
      margin: 14px 0 24px;
    }

    .modal-amount span { font-size: 18px; vertical-align: super; }

    .modal-actions { display: flex; gap: 12px; }

    .btn-cancel {
      flex: 1;
      padding: 14px;
      border-radius: 10px;
      border: 1.5px solid var(--border);
      background: none;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      color: var(--text);
      transition: background 0.15s;
    }

    .btn-cancel:hover { background: #2a2a2a; }

    .btn-confirm {
      flex: 2;
      padding: 14px;
      border-radius: 10px;
      border: none;
      background: linear-gradient(135deg, #FF385C 0%, #E31C5F 100%);
      color: white;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      box-shadow: 0 4px 16px rgba(255,56,92,0.3);
      transition: opacity 0.15s;
    }

    .btn-confirm:hover { opacity: 0.92; }

    .modal-note {
      margin-top: 16px;
      font-size: 12px;
      color: var(--text-soft);
    }

    /* SUCCESS screen */
    .success-icon {
      width: 70px; height: 70px;
      background: #E8F5E9;
      border-radius: 50%;
      display: grid; place-items: center;
      margin: 0 auto 18px;
    }

    .success-icon svg { animation: checkPop 0.5s cubic-bezier(.34,1.56,.64,1) 0.1s both; }

    @keyframes checkPop {
      from { transform: scale(0); }
      to { transform: scale(1); }
    }

    .confetti-dot {
      position: absolute;
      border-radius: 50%;
      animation: confettiFall 1.2s ease-out forwards;
    }

    @keyframes confettiFall {
      0% { transform: translateY(0) rotate(0); opacity: 1; }
      100% { transform: translateY(60px) rotate(360deg); opacity: 0; }
    }
  </style>
</head>
<body>

<!-- TOP BAR -->
<nav class="topbar">
  <a class="topbar-logo" href="#">StayFinder</a>
  <div class="topbar-steps">
    <div class="step">
      <div class="step-dot">1</div>
      <span>Listing</span>
    </div>
    <div class="step-line"></div>
    <div class="step active">
      <div class="step-dot">2</div>
      <span>Review & Pay</span>
    </div>
    <div class="step-line"></div>
    <div class="step">
      <div class="step-dot">3</div>
      <span>Confirmation</span>
    </div>
  </div>
</nav>

<!-- PAGE -->
<div class="pg-wrap">
  <h2 class="page-title">Confirm and pay</h2>

  <div class="layout">

    <!-- LEFT -->
    <div>
      <form id="bookingForm">

        <input 
  type="hidden" 
  name="dynamicPrice" 
  value="<%= dynamicPrice %>"
>

        <div class="form-section">
          <div class="section-header">
            <h3>Your trip</h3>
            <p>Select dates and guests for your stay</p>
          </div>
          <div class="section-body">

            <!-- DATES -->
            <div class="date-grid">
              <div class="date-field">
                <label>Check-in</label>
                <input type="date" name="checkIn" required>
              </div>
              <div class="date-field">
                <label>Check-out</label>
                <input type="date" name="checkOut" required>
              </div>
            </div>

            <!-- GUESTS -->
            <div class="guests-row">
              <div>
                <div class="guests-label">Guests</div>
                <div style="font-size:14px; color:var(--text-soft); margin-top:3px;" id="guestLabel">1 guest</div>
              </div>
              <div class="guests-control">
                <button type="button" class="guests-btn" id="guestMinus" disabled>−</button>
                <span id="guestCount">1</span>
                <button type="button" class="guests-btn" id="guestPlus">+</button>
              </div>
            </div>
            <input type="number" name="guests" id="guestsInput" value="1" min="1" max="16">

            <!-- PRICE BREAKDOWN -->
            <div id="priceBreakdown" class="breakdown" style="display:none;">
              <div class="breakdown-row">
                <span id="priceDetail"></span>
                <span>₹<span id="subtotal">0</span></span>
              </div>
              <div class="breakdown-row total">
                <span>Total (INR)</span>
                <span>₹<span id="totalPrice">0</span></span>
              </div>
            </div>

            <input type="hidden" name="totalPrice" id="totalPriceInput">

          </div>

          <!-- CTA -->
          <div class="cta-wrap">
            <div class="divider">Secure checkout</div>
            <button type="submit" class="btn-pay" id="payBtn">
              Reserve now
            </button>
            <p class="btn-note">You won't be charged yet</p>

            <div class="security-row">
              <div class="sec-badge">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Secure
              </div>
              <div class="sec-badge">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Protected
              </div>
              <div class="sec-badge">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="20 6 9 17 4 12"/></svg>
                Free cancellation
              </div>
            </div>
          </div>
        </div>

      </form>
    </div>

    <!-- RIGHT -->
    <div class="sticky-card">
      <div class="hotel-card">
        <div class="hotel-img-wrap">
          <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
          <div class="hotel-badge">
            <span>★</span> Guest favourite
          </div>
        </div>
        <div class="hotel-info">
          <!-- Replace with: <%= listing.title %> -->
          <h3><%= listing.title %></h3>
          <div class="hotel-location">
            <% if (weatherData) { %>

<div style="
  margin-bottom:14px;
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
">

  <div style="
    background:#1f1f1f;
    border:1px solid #333;
    padding:6px 12px;
    border-radius:999px;
    font-size:13px;
    color:#f0f0f0;
  ">
    🌦 <%= weatherData.weather %>
  </div>

  <div style="
    background:#1f1f1f;
    border:1px solid #333;
    padding:6px 12px;
    border-radius:999px;
    font-size:13px;
    color:#f0f0f0;
  ">
    🌡 <%= weatherData.temp %>°C
  </div>

  <div style="
    background:#2a1620;
    border:1px solid #FF385C;
    color:#FF7B93;
    padding:6px 12px;
    border-radius:999px;
    font-size:13px;
    font-weight:600;
  ">
    <%= listing.priceTag || "Dynamic Price" %>
  </div>

</div>

<% } %>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <%= listing.location %>
          </div>
          <div class="stars">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
            <span class="rating-num">4.97</span>
            <span class="review-count">· 124 reviews</span>
          </div>
          <div class="price-line">
            <!-- Replace with: ₹<%= listing.price %> -->
            <span class="price">
  ₹<%= dynamicPrice %>
</span>
            <span class="per-night">/ night</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- PAYMENT MODAL -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal" id="payModal">
    <div class="modal-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF385C" stroke-width="2.2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
    </div>
    <h3>Confirm payment</h3>
    <p>Your total for this stay</p>
    <div class="modal-amount"><span>₹</span><span id="modalAmount">0</span></div>
    <p id="modalNights" style="font-size:13px; color:var(--text-soft); margin-bottom:0;"></p>
    <div class="modal-actions" style="margin-top:24px;">
      <button class="btn-cancel" id="modalCancel">Go back</button>
      <button class="btn-confirm" id="modalConfirm">Pay now</button>
    </div>
    <p class="modal-note">🔒 Payment is encrypted and secure</p>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  const pricePerNight = <%= dynamicPrice %>;

  const checkInInput  = document.querySelector('input[name="checkIn"]');
  const checkOutInput = document.querySelector('input[name="checkOut"]');
  const totalPriceEl  = document.getElementById("totalPrice");
  const totalInput    = document.getElementById("totalPriceInput");
  const priceDetailEl = document.getElementById("priceDetail");
  const subtotalEl    = document.getElementById("subtotal");
  const breakdownBox  = document.getElementById("priceBreakdown");
  const payBtn        = document.getElementById("payBtn");

  const today = new Date().toISOString().split("T")[0];
  checkInInput.min  = today;
  checkOutInput.min = today;

  let isAvailable = false;

  checkInInput.addEventListener("change", () => {
    checkOutInput.min = checkInInput.value;
    checkAvailability();
    calculateTotal();
  });

  checkOutInput.addEventListener("change", () => {
    checkAvailability();
    calculateTotal();
  });

  async function checkAvailability() {
    if (!checkInInput.value || !checkOutInput.value) return;

    const res = await fetch(`/listings/<%= listing._id %>/bookings/check-availability`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        checkIn: checkInInput.value,
        checkOut: checkOutInput.value,
        listingId: "<%= listing._id %>"
      }),
    });

    const data = await res.json();

    if (!data.available) {
      showToast("❌ Already booked for selected dates", "error");
      isAvailable = false;
      payBtn.disabled = true;
    } else {
      showToast("✅ Available!", "success");
      isAvailable = true;
      payBtn.disabled = false;
    }
  }

  function calculateTotal() {

  if (!checkInInput.value || !checkOutInput.value) {
    breakdownBox.style.display = "none";
    totalInput.value = 0;
    return;
  }

  // FIXED DATE FORMAT
  const checkIn = new Date(checkInInput.value + "T00:00:00");
  const checkOut = new Date(checkOutInput.value + "T00:00:00");

  // milliseconds difference
  const diffTime = checkOut.getTime() - checkIn.getTime();

  // convert to nights
  const nights = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

  // invalid dates
  if (nights <= 0 || isNaN(nights)) {
    breakdownBox.style.display = "none";
    totalInput.value = 0;
    return;
  }

  // price calculation
  const subtotal = nights * Number(pricePerNight);

  // extra fees
  const cleaningFee = 1200;
  const serviceFee = 800;

  // final amount
  const finalTotal = subtotal;

  // UI update
  priceDetailEl.textContent =
    `₹${Number(pricePerNight).toLocaleString('en-IN')} × ${nights} night${nights > 1 ? 's' : ''}`;

  subtotalEl.textContent =
    subtotal.toLocaleString('en-IN');

  totalPriceEl.textContent =
    finalTotal.toLocaleString('en-IN');

  totalInput.value = finalTotal;

  breakdownBox.style.display = "block";
}

  // ✅ MODAL FIX
  const overlay      = document.getElementById("modalOverlay");
  const modalAmount  = document.getElementById("modalAmount");
  const modalNights  = document.getElementById("modalNights");
  const modalCancel  = document.getElementById("modalCancel");
  const modalConfirm = document.getElementById("modalConfirm");
  const form         = document.getElementById("bookingForm");

  form.addEventListener("submit", e => {
    e.preventDefault();

    if (!isAvailable) {
      showToast("Please select available dates", "error");
      return;
    }

    if (!totalInput.value || totalInput.value == 0) {
      showToast("Select valid dates", "error");
      return;
    }

    const checkIn = new Date(checkInInput.value + "T00:00:00");
const checkOut = new Date(checkOutInput.value + "T00:00:00");

const nights = Math.ceil(
  (checkOut.getTime() - checkIn.getTime()) /
  (1000 * 60 * 60 * 24)
);

    modalAmount.textContent = Number(totalInput.value).toLocaleString('en-IN');
    modalNights.textContent = `${nights} night${nights > 1 ? 's' : ''}`;

    overlay.classList.add("open");
  });

  modalCancel.addEventListener("click", () => {
    overlay.classList.remove("open");
  });

  modalConfirm.addEventListener("click", async () => {

  try {

    modalConfirm.disabled = true;
    modalConfirm.innerHTML = "Processing...";

    const formData = new FormData(form);

    const response = await fetch(
      "/listings/<%= listing._id %>/bookings/create-checkout-session",
      {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          checkIn: formData.get("checkIn"),
          checkOut: formData.get("checkOut"),
          guests: formData.get("guests")
        })
      }
    );

    const data = await response.json();

    if (data.url) {
      window.location.href = data.url;
    } else {
      showToast("Payment initialization failed", "error");
    }

  } catch (err) {

    console.log(err);

    showToast("Something went wrong", "error");

    modalConfirm.disabled = false;
    modalConfirm.innerHTML = "Pay now";
  }

});

  function showToast(msg, type = "") {
    const t = document.getElementById("toast");
    t.textContent = msg;
    t.className   = `toast ${type} show`;

    setTimeout(() => {
      t.className = `toast ${type}`;
    }, 3000);
  };

</script>
</body>
</html>