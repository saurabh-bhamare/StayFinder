<% layout("/layouts/boilerplate") %>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #0f0e0d;
    --bg2:       #181614;
    --bg3:       #211f1c;
    --surface:   #2a2724;
    --surface2:  #322f2b;
    --ink:       #f0ece6;
    --ink-soft:  #a09890;
    --ink-faint: #5a534c;
    --accent:    #e8503a;
    --accent2:   #f0c060;
    --border:    rgba(240,236,230,0.08);
    --border2:   rgba(240,236,230,0.14);
    --radius:    14px;
    --radius-lg: 20px;
    --font-head: 'Playfair Display', Georgia, serif;
    --font-body: 'Outfit', sans-serif;
  }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--ink);
    min-height: 100vh;
  }

  /* ── HERO HEADER ── */
  .hero-header {
    position: relative;
    overflow: hidden;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    padding: 56px 40px 48px;
  }

  /* subtle texture dots */
  .hero-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(240,236,230,0.04) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  /* warm glow top-left */
  .hero-header::after {
    content: '';
    position: absolute;
    top: -80px; left: -80px;
    width: 360px; height: 360px;
    background: radial-gradient(circle, rgba(232,80,58,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    max-width: 1160px;
    margin: 0 auto;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .hero-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .hero-title {
    font-family: var(--font-head);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    line-height: 1.1;
    color: var(--ink);
    letter-spacing: -0.5px;
  }

  .hero-title em {
    font-style: italic;
    color: var(--accent2);
  }

  .hero-sub {
    margin-top: 10px;
    font-size: 14px;
    color: var(--ink-soft);
    font-weight: 300;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 24px;
    background: var(--accent);
    color: #fff;
    border-radius: 100px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    flex-shrink: 0;
  }

  .hero-cta:hover { background: #d4432f; transform: translateY(-1px); }
  .hero-cta:active { transform: scale(0.98); }

  /* ── STATS BAR ── */
  .stats-bar {
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    padding: 0 40px;
  }

  .stats-inner {
    max-width: 1160px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .stat-item {
    padding: 18px 32px 18px 0;
    margin-right: 32px;
    border-right: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .stat-item:last-child { border-right: none; }

  .stat-num {
    font-family: var(--font-head);
    font-size: 24px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1;
  }

  .stat-label {
    font-size: 11px;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 400;
    line-height: 1.3;
  }

  /* ── FILTER TABS ── */
  .filter-bar {
    max-width: 1160px;
    margin: 0 auto;
    padding: 36px 40px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .tabs {
    display: flex;
    gap: 4px;
    background: var(--bg3);
    padding: 4px;
    border-radius: 100px;
    border: 1px solid var(--border);
  }

  .tab {
    padding: 8px 20px;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-soft);
    cursor: pointer;
    border-radius: 100px;
    transition: all 0.2s;
    user-select: none;
    white-space: nowrap;
  }

  .tab.active {
    background: var(--ink);
    color: var(--bg);
    font-weight: 600;
  }

  .tab:hover:not(.active) { color: var(--ink); }

  .filter-right {
    font-size: 13px;
    color: var(--ink-faint);
  }

  /* ── CARDS GRID ── */
  .page-body {
    max-width: 1160px;
    margin: 0 auto;
    padding: 32px 40px 100px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }

  /* ── TRIP CARD ── */
  .trip-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    animation: card-in 0.5s cubic-bezier(0.22,1,0.36,1) both;
    cursor: pointer;
  }

  .trip-card:hover {
    border-color: var(--border2);
    transform: translateY(-3px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .trip-card:nth-child(1) { animation-delay: 0.04s; }
  .trip-card:nth-child(2) { animation-delay: 0.09s; }
  .trip-card:nth-child(3) { animation-delay: 0.14s; }
  .trip-card:nth-child(4) { animation-delay: 0.19s; }
  .trip-card:nth-child(5) { animation-delay: 0.24s; }
  .trip-card:nth-child(6) { animation-delay: 0.29s; }

  /* image */
  .card-img {
    position: relative;
    height: 210px;
    overflow: hidden;
  }

  .card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22,1,0.36,1);
    filter: brightness(0.88);
  }

  .trip-card:hover .card-img img {
    transform: scale(1.06);
    filter: brightness(0.95);
  }

  .card-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, transparent 40%, rgba(15,14,13,0.7) 100%);
    pointer-events: none;
  }

  /* floating date strip on image */
  .img-date-strip {
    position: absolute;
    bottom: 14px;
    left: 14px;
    right: 14px;
    display: flex;
    gap: 8px;
    align-items: center;
    pointer-events: none;
  }

  .img-date-chip {
    background: rgba(15,14,13,0.75);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(240,236,230,0.12);
    border-radius: 8px;
    padding: 6px 10px;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .img-date-chip .dchip-label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(240,236,230,0.5);
  }

  .img-date-chip .dchip-val {
    font-size: 12px;
    font-weight: 500;
    color: #f0ece6;
  }

  .img-date-arrow {
    color: rgba(240,236,230,0.4);
    font-size: 12px;
    flex-shrink: 0;
  }

  /* status badge */
  .status-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    padding: 4px 11px;
    border-radius: 100px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .badge-upcoming {
    background: rgba(240,192,96,0.2);
    color: var(--accent2);
    border: 1px solid rgba(240,192,96,0.3);
  }

  .badge-completed {
    background: rgba(90,83,76,0.4);
    color: var(--ink-soft);
    border: 1px solid rgba(90,83,76,0.5);
  }

  /* card body */
  .card-body { padding: 20px; }

  .card-location {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 7px;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .card-location::before {
    content: '';
    display: inline-block;
    width: 4px; height: 4px;
    background: var(--accent);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .card-title {
    font-family: var(--font-head);
    font-size: 17px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 16px;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 16px;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .price-block {}

  .price-amount {
    font-family: var(--font-head);
    font-size: 20px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1;
  }

  .price-label {
    font-size: 11px;
    color: var(--ink-faint);
    margin-top: 2px;
  }

  .nights-pill {
    background: var(--surface);
    border: 1px solid var(--border2);
    color: var(--ink-soft);
    font-size: 12px;
    font-weight: 500;
    padding: 5px 12px;
    border-radius: 100px;
  }

  /* ── EMPTY STATE ── */
  .empty-state {
    display: none;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 100px 24px;
  }

  .empty-state.visible { display: flex; }

  .empty-art {
    width: 80px; height: 80px;
    background: var(--bg3);
    border: 1px solid var(--border2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    margin-bottom: 28px;
  }

  .empty-state h3 {
    font-family: var(--font-head);
    font-size: 26px;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .empty-state p {
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.7;
    max-width: 320px;
    margin-bottom: 32px;
    font-weight: 300;
  }

  .empty-cta {
    padding: 14px 32px;
    background: var(--ink);
    color: var(--bg);
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .empty-cta:hover { opacity: 0.85; }

  @media (max-width: 640px) {
    .hero-header, .stats-bar { padding-left: 20px; padding-right: 20px; }
    .filter-bar, .page-body  { padding-left: 20px; padding-right: 20px; }
    .cards-grid { grid-template-columns: 1fr; }
  }

  .cancel-btn {
  width: 100%;
  padding: 10px;
  border-radius: 10px;
  background: transparent;
  border: 1px solid rgba(232,80,58,0.5);
  color: #e8503a;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: 0.2s;
}

.cancel-btn:hover {
  background: rgba(232,80,58,0.1);
  border-color: #e8503a;
}


</style>

<!-- HERO HEADER -->
<div class="hero-header">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">Your journey</div>
      <h1 class="hero-title">My <em>Trips</em></h1>
      <p class="hero-sub" id="heroSub">Loading your adventures…</p>
    </div>
    <a href="/listings" class="hero-cta">
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      Explore stays
    </a>
  </div>
</div>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="stats-inner">
    <div class="stat-item">
      <div>
        <div class="stat-num" id="statTotal">—</div>
        <div class="stat-label">Total trips</div>
      </div>
    </div>
    <div class="stat-item">
      <div>
        <div class="stat-num" id="statUpcoming">—</div>
        <div class="stat-label">Upcoming</div>
      </div>
    </div>
    <div class="stat-item">
      <div>
        <div class="stat-num" id="statNights">—</div>
        <div class="stat-label">Nights booked</div>
      </div>
    </div>
  </div>
</div>

<!-- FILTER BAR -->
<div class="filter-bar">
  <div class="tabs">
    <div class="tab active" data-filter="all">All trips</div>
    <div class="tab" data-filter="upcoming">Upcoming</div>
    <div class="tab" data-filter="completed">Completed</div>
  </div>
  <div class="filter-right" id="filterCount"></div>
</div>

<!-- CARDS -->
<div class="page-body">
  <div class="cards-grid" id="cardsGrid">

    <% let totalNights = 0, upcomingCount = 0; %>

    <% bookings.forEach((b, i) => { %>
      <% if (b.listing) { %>
        <%
          const checkIn   = new Date(b.checkIn);
          const checkOut  = new Date(b.checkOut);
          const nights    = Math.round((checkOut - checkIn) / (1000*60*60*24));
          const isUpcoming = checkIn >= new Date();

          const fmtShort = d => d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });
          const fmtFull  = d => d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
        %>

        <div class="trip-card" data-status="<%= isUpcoming ? 'upcoming' : 'completed' %>" data-nights="<%= nights %>">

          <div class="card-img">
            <img src="<%= b.listing.image.url %>" alt="<%= b.listing.title %>">
            <div class="card-img-overlay"></div>

            <span class="status-badge <%= isUpcoming ? 'badge-upcoming' : 'badge-completed' %>">
              <%= isUpcoming ? 'Upcoming' : 'Completed' %>
            </span>

            <div class="img-date-strip">
              <div class="img-date-chip">
                <span class="dchip-label">In</span>
                <span class="dchip-val"><%= fmtShort(checkIn) %></span>
              </div>
              <span class="img-date-arrow">→</span>
              <div class="img-date-chip">
                <span class="dchip-label">Out</span>
                <span class="dchip-val"><%= fmtShort(checkOut) %></span>
              </div>
            </div>
          </div>

          <div class="card-body">
            <div class="card-location">
              <%= b.listing.location %><% if (b.listing.country) { %>, <%= b.listing.country %><% } %>
            </div>

            <div class="card-title"><%= b.listing.title %></div>

            <div class="card-divider"></div>

            <div class="card-footer" style="flex-direction: column; align-items: stretch; gap: 12px;">

  <div style="display:flex; justify-content: space-between; align-items:center;">
    <div class="price-block">
      <div class="price-amount">₹<%= (b.totalPrice || 0).toLocaleString('en-IN') %></div>
      <div class="price-label">total paid</div>
    </div>
    <div class="nights-pill"><%= nights %> night<%= nights !== 1 ? 's' : '' %></div>
  </div>

  <!-- Cancel Booking Button -->
  <form action="/bookings/<%= b._id %>?_method=DELETE" method="POST">
  <button 
    type="submit"
    class="cancel-btn <%= !isUpcoming ? 'disabled-btn' : '' %>"
    <%= !isUpcoming ? 'disabled title="Cannot cancel completed bookings"' : '' %>
    onclick="return <%= isUpcoming ? 'confirm(\'Cancel this booking?\')' : 'false' %>">
    
    <%= isUpcoming ? 'Cancel booking' : 'Completed' %>
  </button>
</form>

</div>
          </div>

        </div>

      <% } %>
    <% }) %>

  </div>

  <div class="empty-state" id="emptyState">
    <div class="empty-art">✈️</div>
    <h3>No trips here</h3>
    <p>When you book a stay, your trips will show up right here.</p>
    <a href="/listings" class="empty-cta">Start exploring</a>
  </div>
</div>

<script>
  const cards     = [...document.querySelectorAll('.trip-card')];
  const emptyEl   = document.getElementById('emptyState');
  const countEl   = document.getElementById('filterCount');

  // compute stats
  const totalNights   = cards.reduce((s, c) => s + (+c.dataset.nights || 0), 0);
  const upcomingCards = cards.filter(c => c.dataset.status === 'upcoming');

  document.getElementById('statTotal').textContent    = cards.length;
  document.getElementById('statUpcoming').textContent = upcomingCards.length;
  document.getElementById('statNights').textContent   = totalNights;
  document.getElementById('heroSub').textContent      =
    cards.length === 0 ? 'No trips booked yet' :
    cards.length === 1 ? '1 trip in your collection' :
    cards.length + ' trips in your collection';

  function showCount(n) {
    countEl.textContent = n === 0 ? '' : n + ' trip' + (n !== 1 ? 's' : '');
  }

  showCount(cards.length);

  // tab filter
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      const filter = tab.dataset.filter;
      let visible = 0;
      cards.forEach(card => {
        const show = filter === 'all' || card.dataset.status === filter;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      emptyEl.classList.toggle('visible', visible === 0);
      showCount(visible);
    });
  });

  if (cards.length === 0) emptyEl.classList.add('visible');
</script>
