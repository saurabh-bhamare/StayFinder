<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display&display=swap" rel="stylesheet">

<style>
  :root {
    --nb-bg:        #0c0b0a;
    --nb-bg2:       #141210;
    --nb-glass:     rgba(20,18,16,0.82);
    --nb-border:    rgba(255,255,255,0.07);
    --nb-border2:   rgba(255,255,255,0.13);
    --nb-ink:       #f2ede6;
    --nb-ink-soft:  #8c8278;
    --nb-ink-faint: #4e4740;
    --nb-accent:    #e04e35;
    --nb-accent2:   #ff6b4a;
    --nb-surface:   #1e1b18;
    --nb-surface2:  #282420;
    --nb-font:      'DM Sans', -apple-system, sans-serif;
    --nb-serif:     'DM Serif Display', Georgia, serif;
  }

  /* ── NAV SHELL ── */
  .navbar {
    background: var(--nb-glass) !important;
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    border-bottom: 1px solid var(--nb-border);
    padding: 0 40px;
    height: 68px;
    box-shadow: 0 1px 0 rgba(255,255,255,0.03), 0 8px 32px rgba(0,0,0,0.4) !important;
    position: sticky;
    top: 0;
    z-index: 1000;
    transition: background 0.3s;
  }

  .container-fluid { padding: 0; height: 100%; align-items: center; }

  /* ── LOGO ── */
  .navbar-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
    margin-right: 32px;
  }

  .brand-mark {
    width: 34px;
    height: 34px;
    background: var(--nb-accent);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 14px rgba(224,78,53,0.35);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .navbar-brand:hover .brand-mark {
    box-shadow: 0 6px 20px rgba(224,78,53,0.5);
    transform: translateY(-1px);
  }

  .brand-mark svg { display: block; }

  .brand-wordmark {
    font-family: var(--nb-serif);
    font-size: 19px;
    color: var(--nb-ink);
    letter-spacing: -0.2px;
    line-height: 1;
  }

  .brand-wordmark span { color: var(--nb-accent); }

  /* ── SEARCH FORM ── */
  .search-wrap {
    flex: 1;
    max-width: 460px;
    margin: 0 auto;
  }

  .search-box {
    display: flex;
    align-items: center;
    background: var(--nb-surface);
    border: 1px solid var(--nb-border);
    border-radius: 100px;
    padding: 0 5px 0 18px;
    height: 42px;
    gap: 6px;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
  }

  .search-box:focus-within {
    border-color: rgba(224,78,53,0.4);
    box-shadow: 0 0 0 3px rgba(224,78,53,0.1);
    background: var(--nb-surface2);
  }

  .search-box .search-icon {
    color: var(--nb-ink-faint);
    font-size: 12px;
    flex-shrink: 0;
    transition: color 0.2s;
  }

  .search-box:focus-within .search-icon { color: var(--nb-ink-soft); }

  .search-box input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--nb-font);
    font-size: 13.5px;
    font-weight: 400;
    color: var(--nb-ink);
    caret-color: var(--nb-accent);
    min-width: 0;
  }

  .search-box input::placeholder { color: var(--nb-ink-faint); }

  .search-divider {
    width: 1px;
    height: 18px;
    background: var(--nb-border2);
    flex-shrink: 0;
  }

  /* filter pill inside search */
  .filter-pill {
    height: 32px;
    padding: 0 12px;
    background: transparent;
    border: none;
    border-radius: 100px;
    color: var(--nb-ink-soft);
    font-family: var(--nb-font);
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .filter-pill:hover { background: var(--nb-surface2); color: var(--nb-ink); }
  .filter-pill i { font-size: 10px; opacity: 0.7; }

  .search-submit {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--nb-accent);
    border: none;
    color: #fff;
    font-size: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 2px 8px rgba(224,78,53,0.3);
  }

  .search-submit:hover {
    background: var(--nb-accent2);
    transform: scale(1.08);
    box-shadow: 0 4px 14px rgba(224,78,53,0.45);
  }

  /* ── FILTER DROPDOWN ── */
  .filter-box {
    width: 300px;
    background: var(--nb-bg2) !important;
    border: 1px solid var(--nb-border2) !important;
    border-radius: 18px !important;
    padding: 22px !important;
    box-shadow: 0 24px 64px rgba(0,0,0,0.6) !important;
    margin-top: 10px !important;
  }

  .filter-box .fbox-heading {
    font-family: var(--nb-font);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--nb-ink-faint);
    display: block;
    margin-bottom: 8px;
  }

  .filter-box .form-select,
  .filter-box .form-control {
    background: var(--nb-bg) !important;
    border: 1px solid var(--nb-border2) !important;
    color: var(--nb-ink) !important;
    border-radius: 10px !important;
    font-size: 13px;
    font-family: var(--nb-font);
    padding: 10px 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .filter-box .form-select:focus,
  .filter-box .form-control:focus {
    box-shadow: 0 0 0 2px rgba(224,78,53,0.2) !important;
    border-color: rgba(224,78,53,0.4) !important;
    outline: none;
  }

  .filter-box .form-select option { background: var(--nb-bg2); color: var(--nb-ink); }

  .filter-box .price-row { display: flex; gap: 8px; }
  .filter-box .price-row .form-control { flex: 1; min-width: 0; }

  .filter-box .btn-apply {
    width: 100%;
    padding: 11px;
    background: var(--nb-accent);
    border: none;
    border-radius: 100px;
    color: #fff;
    font-family: var(--nb-font);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: background 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 14px rgba(224,78,53,0.3);
    margin-top: 2px;
  }

  .filter-box .btn-apply:hover {
    background: var(--nb-accent2);
    box-shadow: 0 6px 20px rgba(224,78,53,0.45);
  }

  /* ── NAV LINKS (for "Dashboard" etc.) ── */
  .nb-nav-link {
    font-family: var(--nb-font);
    font-size: 13px;
    font-weight: 500;
    color: var(--nb-ink-soft);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 100px;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }

  .nb-nav-link:hover { color: var(--nb-ink); background: var(--nb-surface); }

  /* ── PROFILE BUTTON ── */
  .profile-menu-btn {
    display: flex;
    align-items: center;
    gap: 9px;
    background: var(--nb-surface);
    border: 1px solid var(--nb-border);
    border-radius: 100px;
    padding: 5px 5px 5px 14px;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    flex-shrink: 0;
  }

  .profile-menu-btn:hover {
    border-color: var(--nb-border2);
    background: var(--nb-surface2);
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  .profile-menu-btn .bars-icon {
    color: var(--nb-ink-soft);
    font-size: 12px;
    line-height: 1;
    transition: color 0.15s;
  }

  .profile-menu-btn:hover .bars-icon { color: var(--nb-ink); }

  .profile-circle {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--nb-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    color: #fff;
    font-weight: 600;
    font-size: 12px;
    font-family: var(--nb-font);
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(224,78,53,0.3);
  }

  .nav-avatar { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ── PROFILE DROPDOWN ── */
  .airbnb-dropdown {
    background: var(--nb-bg2) !important;
    border: 1px solid var(--nb-border2) !important;
    border-radius: 18px !important;
    padding: 8px !important;
    min-width: 220px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.03) !important;
    margin-top: 10px !important;
  }

  .airbnb-dropdown .dropdown-section-label {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--nb-ink-faint);
    padding: 8px 14px 4px;
    display: block;
  }

  .airbnb-dropdown .dropdown-item {
    font-family: var(--nb-font);
    font-size: 13.5px;
    font-weight: 400;
    color: var(--nb-ink-soft);
    border-radius: 10px;
    padding: 9px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: background 0.12s, color 0.12s;
    text-decoration: none;
    cursor: pointer;
  }

  .airbnb-dropdown .dropdown-item .di-icon {
    width: 16px;
    text-align: center;
    font-size: 12px;
    opacity: 0.7;
    flex-shrink: 0;
  }

  .airbnb-dropdown .dropdown-item:hover {
    background: var(--nb-surface) !important;
    color: var(--nb-ink) !important;
  }

  .airbnb-dropdown .dropdown-item:hover .di-icon { opacity: 1; }

  .airbnb-dropdown .dropdown-item.is-strong { color: var(--nb-ink); font-weight: 500; }

  .airbnb-dropdown .dropdown-item.is-accent {
    color: var(--nb-accent2);
    font-weight: 500;
  }

  .airbnb-dropdown .dropdown-item.is-danger { color: #d96464 !important; }
  .airbnb-dropdown .dropdown-item.is-danger:hover { background: rgba(217,100,100,0.07) !important; }

  .airbnb-dropdown .dropdown-divider {
    border-color: var(--nb-border) !important;
    margin: 6px 8px !important;
  }

  /* ── TOGGLER ── */
  .navbar-toggler {
    border: 1px solid var(--nb-border2) !important;
    border-radius: 10px !important;
    padding: 7px 10px;
    background: var(--nb-surface) !important;
  }

  .navbar-toggler:focus { box-shadow: 0 0 0 2px rgba(224,78,53,0.2) !important; }

  .navbar-toggler-icon {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(242,237,230,0.7)' stroke-linecap='round' stroke-width='2' d='M4 8h22M4 15h22M4 22h22'/%3e%3c/svg%3e") !important;
  }

  /* ── MOBILE ── */
  @media (max-width: 767px) {
    .navbar { height: auto; padding: 14px 20px; }
    .search-wrap { max-width: 100%; margin: 12px 0 8px; }
    .navbar-collapse { padding-bottom: 12px; gap: 8px; flex-direction: column; align-items: stretch; }
    .nb-nav-link { text-align: center; }
  }

  /* ============================= */
/* RESPONSIVE FIXES */
/* ============================= */

@media (max-width: 992px) {

  .search-wrap {
    max-width: 100%;
  }

  .search-box {
    flex-wrap: wrap;
    height: auto;
    padding: 10px;
    gap: 8px;
    border-radius: 20px;
  }

  .search-box input {
    width: 100%;
    padding: 8px 0;
  }

  .search-divider {
    display: none;
  }

  .filter-pill {
    width: 48%;
    justify-content: center;
  }

  .search-submit {
    width: 48%;
    border-radius: 12px;
  }
}

@media (max-width: 576px) {

  .navbar {
    padding: 10px 14px;
  }

  .brand-wordmark {
    font-size: 16px;
  }

  .search-box {
    flex-direction: column;
    align-items: stretch;
  }

  .filter-pill,
  .search-submit {
    width: 100%;
  }

  .filter-box {
    width: 100%;
  }

  .profile-menu-btn {
    padding: 5px 8px;
  }
}

</style>

<nav class="navbar navbar-expand-md sticky-top">
  <div class="container-fluid">

    <!-- LOGO -->
    <a class="navbar-brand" href="/listings">
      <div class="brand-mark">
        <svg width="18" height="18" viewBox="0 0 32 32" fill="none">
          <path d="M16 3C9.925 3 5 7.925 5 14c0 4.9 3.025 9.125 7.35 10.875L16 29l3.65-4.125C23.975 23.125 27 18.9 27 14c0-6.075-4.925-11-11-11z" fill="white"/>
          <circle cx="16" cy="14" r="4" fill="#e04e35"/>
        </svg>
      </div>
      <div class="brand-wordmark">Stay<span>Finder</span></div>
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">

  <!-- LEFT / CENTER SEARCH -->
  <div class="search-wrap d-flex justify-content-center">
    <form class="search-box w-100" action="/listings" method="GET">
      <i class="fa-solid fa-magnifying-glass search-icon"></i>

      <input type="text" name="q" placeholder="Search destinations…" autocomplete="off">

      <div class="search-divider"></div>

      <div class="dropdown">
        <button type="button" class="filter-pill" data-bs-toggle="dropdown">
          <i class="fa-solid fa-sliders"></i> Filters
        </button>

        <div class="dropdown-menu filter-box">
          <label class="fbox-heading">Category</label>
          <select name="category" class="form-select mb-3">
            <option value="">All categories</option>
            <option>Trending</option>
            <option>Beach</option>
            <option>Camping</option>
            <option>Mountains</option>
            <option>City</option>
          </select>

          <label class="fbox-heading">Price range</label>
          <div class="price-row mb-3">
            <input type="number" name="minPrice" class="form-control" placeholder="Min ₹">
            <input type="number" name="maxPrice" class="form-control" placeholder="Max ₹">
          </div>

          <button type="submit" class="btn-apply">Apply filters</button>
        </div>
      </div>

      <button type="submit" class="search-submit">
        <i class="fa-solid fa-arrow-right"></i>
      </button>
    </form>
  </div>

  <!-- RIGHT SIDE -->
  <div class="d-flex align-items-center ms-auto mt-2 mt-md-0">
    <!-- profile dropdown stays same -->
        <div class="dropdown">
          <button class="profile-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="User menu">
            <span class="bars-icon"><i class="fa-solid fa-bars"></i></span>
            <div class="profile-circle">
              <% if (currUser && currUser.avatar && currUser.avatar.url) { %>
                <img src="<%= currUser.avatar.url %>" class="nav-avatar" alt="avatar">
              <% } else if (currUser) { %>
                <%= currUser.username.charAt(0).toUpperCase() %>
              <% } else { %>
                <i class="fa-solid fa-user" style="font-size:11px;"></i>
              <% } %>
            </div>
          </button>

          <ul class="dropdown-menu dropdown-menu-end airbnb-dropdown">
            <% if (!currUser) { %>

              <li><a class="dropdown-item is-strong" href="/login">
                <span class="di-icon"><i class="fa-regular fa-circle-user"></i></span> Log in
              </a></li>
              <li><a class="dropdown-item" href="/signup">
                <span class="di-icon"><i class="fa-solid fa-user-plus"></i></span> Sign up
              </a></li>

            <% } else { %>

              <li><span class="dropdown-section-label">Account</span></li>
              <li><a class="dropdown-item" href="/profile">
                <span class="di-icon"><i class="fa-regular fa-circle-user"></i></span> My Profile
              </a></li>
              <li><a class="dropdown-item" href="/bookings">
                <span class="di-icon"><i class="fa-regular fa-calendar-check"></i></span> My Bookings
              </a></li>
              <li><a class="dropdown-item" href="/wishlist">
                <span class="di-icon"><i class="fa-regular fa-heart"></i></span> Wishlist
              </a></li>

              <li><hr class="dropdown-divider"></li>
              <li><span class="dropdown-section-label">Hosting</span></li>
              <li><a class="dropdown-item" href="/mylistings">
                <span class="di-icon"><i class="fa-regular fa-building"></i></span> My Listings
              </a></li>
              <li><a class="dropdown-item is-accent" href="/listings/new">
                <span class="di-icon"><i class="fa-solid fa-plus"></i></span> Add Listing
              </a></li>
              <li><a class="dropdown-item is-strong" href="/dashboard">
                <span class="di-icon"><i class="fa-solid fa-gauge-high"></i></span> Dashboard
              </a></li>

              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item is-danger" href="/logout">
                <span class="di-icon"><i class="fa-solid fa-arrow-right-from-bracket"></i></span> Log out
              </a></li>

            <% } %>
          </ul>
        </div>
      </div>

    </div>
  </div>
</nav>
