<style>
  .location-section {
    padding: 1.5rem 0;
  }

  .location-label {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #888;
    margin: 0 0 0.5rem;
  }

  .location-heading {
    font-size: 22px;
    font-weight: 500;
    color: #f1f1f1;
    margin: 0 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .location-heading .pin-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .location-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
  }

  .location-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    background: #1e1e1e;
    border: 0.5px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.25rem 1rem;
    transition: border-color 0.15s, background 0.15s;
    cursor: pointer;
  }

  .location-card:hover {
    border-color: rgba(255, 255, 255, 0.25);
    background: #2a2a2a;
  }

  .location-card-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: #1a2535;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .location-card h2 {
    font-size: 14px;
    font-weight: 500;
    color: #f1f1f1;
    margin: 0 0 2px;
  }

  .location-card p {
    font-size: 12px;
    color: #888;
    margin: 0;
  }

  body {
    background: #121212;
  }
</style>

<div class="location-section">
  <p class="location-label">Choose your city</p>
  <h1 class="location-heading">
    <svg class="pin-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 2C7.24 2 5 4.24 5 7c0 4 5 11 5 11s5-7 5-11c0-2.76-2.24-5-5-5z" fill="#378ADD"/>
      <circle cx="10" cy="7" r="2" fill="#121212"/>
    </svg>
    Select location for <%= festivalName %>
  </h1>

  <div class="location-grid">
    <% locations.forEach(loc => { %>
      <a href="<%= '/listings/festivals/' + festivalName + '/' + loc.city %>" class="location-card">
        <div class="location-card-icon">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
            <path d="M10 2C7.24 2 5 4.24 5 7c0 4 5 11 5 11s5-7 5-11c0-2.76-2.24-5-5-5z" fill="#378ADD"/>
            <circle cx="10" cy="7" r="2" fill="#1a2535"/>
          </svg>
        </div>
        <div>
          <h2><%= loc.city %></h2>
          <p><%= loc.spot %></p>
        </div>
      </a>
    <% }) %>
  </div>
</div>