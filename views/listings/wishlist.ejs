<% layout("/layouts/boilerplate") %>

<style>
:root {
  --bg: #000000;
  --card: #0a0a0a;
  --card-hover: #111111;
  --border: #1e1e1e;
  --text: #f0f0f0;
  --sub: #888888;
  --price: #cccccc;
  --heart-bg: rgba(10,10,10,0.85);
  --heart-border: #2a2a2a;
}

body { background: var(--bg); }

.wishlist-container { max-width: 1100px; margin: 0 auto; padding: 40px 24px; }

.page-header {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: 32px;
}
.page-title { font-size: 22px; font-weight: 500; color: var(--text); }
.count-badge {
  font-size: 12px; color: var(--sub);
  background: #111111; border: 0.5px solid #222222;
  padding: 4px 12px; border-radius: 99px;
}

.empty-state { text-align: center; padding: 80px 0; color: var(--sub); }
.empty-icon  { font-size: 40px; margin-bottom: 12px; opacity: .3; }

.wishlist-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
  gap: 24px;
}

.card-link { text-decoration: none; display: block; }

.wishlist-card {
  background: var(--card);
  border: 0.5px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  transition: .2s ease;
}
.wishlist-card:hover {
  background: var(--card-hover);
  border-color: #2a2a2a;
  transform: translateY(-2px);
}

.image-wrapper {
  position: relative; width: 100%;
  height: 220px; background: #111; overflow: hidden;
}
.wishlist-img {
  width: 100%; height: 100%;
  object-fit: cover; display: block; transition: transform .3s;
}
.wishlist-card:hover .wishlist-img { transform: scale(1.03); }

.remove-btn {
  position: absolute; top: 12px; right: 12px;
  width: 36px; height: 36px; border-radius: 50%;
  background: var(--heart-bg);
  border: 0.5px solid var(--heart-border);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: .15s;
  backdrop-filter: blur(6px);
}
.remove-btn:hover {
  transform: scale(1.12);
  background: #1a0608;
  border-color: #FF385C;
}

.card-body { padding: 14px 16px 16px; }

.listing-title {
  font-size: 14px; font-weight: 500; color: var(--text);
  margin-bottom: 4px; white-space: nowrap;
  overflow: hidden; text-overflow: ellipsis;
}
.listing-loc {
  font-size: 12px; color: var(--sub); margin-bottom: 8px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.listing-price { font-size: 14px; color: var(--price); }
.listing-price strong { font-weight: 500; color: var(--text); font-size: 15px; }
</style>

<div class="wishlist-container">

  <div class="page-header">
    <div class="page-title">Your wishlist</div>
    <% if (listings && listings.length > 0) { %>
      <span class="count-badge"><%= listings.length %> saved</span>
    <% } %>
  </div>

  <% if (!listings || listings.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">❤️</div>
      <p>No saved listings yet</p>
    </div>
  <% } else { %>

    <div class="wishlist-grid">
      <% listings.forEach(listing => { %>

        <div>
          <a href="/listings/<%= listing._id %>" class="card-link">
            <div class="wishlist-card">

              <div class="image-wrapper">
                <img src="<%= listing.image?.url %>" class="wishlist-img" alt="<%= listing.title %>">

                <button
                  class="remove-btn"
                  title="Remove from wishlist"
                  onclick="event.preventDefault(); removeFav('<%= listing._id %>')"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#FF385C" stroke="#FF385C" stroke-width="1.5">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                  </svg>
                </button>
              </div>

              <div class="card-body">
                <div class="listing-title"><%= listing.title %></div>
                <div class="listing-loc"><%= listing.location %>, <%= listing.country %></div>
                <div class="listing-price">
                  <strong>₹<%= listing.price.toLocaleString("en-IN") %></strong> / night
                </div>
              </div>

            </div>
          </a>
        </div>

      <% }) %>
    </div>

  <% } %>

</div>

<script>
async function removeFav(id) {
  await fetch(`/favorite/${id}`, { method: "POST" });
  location.reload();
}
</script>