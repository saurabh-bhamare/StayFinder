            <%= listing.location %>, <%= listing.country %>
          </div>
          <p>
  <% if (listing.amenities && listing.amenities.length > 0) { %>
    <%= listing.amenities.slice(0, 3).join(", ") %>
  <% } %>
</p>

          <!-- List-view price (hidden in grid) -->
          <div class="lv-price" style="display:none">
            ₹<%= listing.price.toLocaleString('en-IN') %>
            <small>per night</small>
          </div>
        </div>
      </a>

      <!-- ━━━━━━━━━━━━━━ BOOK NOW BUTTON ━━━━━━━━━━━━━━ -->
      <div class="book-now-form">
        <form action="/listings/<%= listing._id %>/bookings/new" method="GET">
          <button type="submit" class="book-now-btn">
            <span class="btn-icon">🏡</span>
            <span class="btn-label">Book Now</span>
            <span class="btn-arrow">→</span>
          </button>
        </form>
      </div>

    </div>
  <% } %>

</div>

<script>

  const searchInput = document.getElementById('searchInput');
const searchBtn = document.getElementById('searchBtn');
const sortSel = document.getElementById('sortSel');

  /* ── Category rail ── */

  document.querySelectorAll('.cat-pill').forEach(p => {
    p.addEventListener('click', () => {
      document.querySelectorAll('.cat-pill').forEach(x => x.classList.remove('on'));
      p.classList.add('on');
    });
  });

  /* ── Search ── */
  const searchEl  = document.getElementById('searchInput');
  const grid      = document.getElementById('listingGrid');
  const countEl   = document.getElementById('countDisplay');
  const getCards  = () => [...document.querySelectorAll('.lcard')];

  function applyFilter() {
    const q = searchEl.value.toLowerCase().trim();
    let vis = 0;
    getCards().forEach(c => {
      const match = !q || c.dataset.title.includes(q) || c.dataset.loc.includes(q);
      c.style.display = match ? '' : 'none';
      if (match) vis++;
    });
    countEl.textContent = vis;
  }

  searchEl.addEventListener('input', applyFilter);
  document.querySelector('.search-exec').addEventListener('click', applyFilter);

  /* ── Sort ── */
  document.getElementById('sortSel').addEventListener('change', function () {
    const cards = getCards().filter(c => c.style.display !== 'none');
    cards.sort((a, b) => {
      if (this.value === 'asc')  return +a.dataset.price - +b.dataset.price;
      if (this.value === 'desc') return +b.dataset.price - +a.dataset.price;
      return 0;
    }).forEach(c => grid.appendChild(c));
  });

  /* ── View toggle ── */
  const gridBtn = document.getElementById('gridBtn');
  const listBtn = document.getElementById('listBtn');

  gridBtn.addEventListener('click', () => {
    grid.classList.remove('list-view');
    gridBtn.classList.add('on'); listBtn.classList.remove('on');
    document.querySelectorAll('.lv-price').forEach(el => el.style.display = 'none');
  });

  listBtn.addEventListener('click', () => {
    grid.classList.add('list-view');
    listBtn.classList.add('on'); gridBtn.classList.remove('on');
    document.querySelectorAll('.lv-price').forEach(el => el.style.display = 'block');
  });
</script>


<script>
document.querySelectorAll(".ajax-fav-form").forEach(form => {

  const btn = form.querySelector(".fav-btn");
  const heart = form.querySelector(".heart-icon");
  const listingId = form.dataset.id;

  btn.addEventListener("click", async (e) => {

    e.preventDefault();

    try {

      const res = await fetch(`/favorite/${listingId}`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        }
      });

      const data = await res.json();

      if (data.isFav) {
        btn.classList.add("liked");
        heart.textContent = "❤️";
      } else {
        btn.classList.remove("liked");
        heart.textContent = "🤍";
      }

    } catch (err) {
      console.log(err);
    }

  });

});
</script>