    <div class="hero-eyebrow">Explore stays</div>
    <h1 class="hero-h1">Your next<br><em>adventure</em> awaits</h1>
    <p class="hero-sub">Discover handpicked homes, villas &amp; hidden escapes.</p>
    <p class="result-tag" style="margin-top:14px">
      <strong id="countDisplay"><%= allListing.length %></strong> places to stay
    </p>
  </div>
</div>

<a href="/listings/festivals" class="btn">Explore Festivals</a>

<!-- ━━━━━━━━━━━━━━ GRID ━━━━━━━━━━━━━━ -->
<div class="listing-grid" id="listingGrid">

  <% if (allListing.length === 0) { %>
    <div class="empty">
      <span class="empty-emoji">🏡</span>
      <h3>No listings yet</h3>
      <p>Try a different search or check back soon.</p>
    </div>
  <% } %>

  <% for (let listing of allListing) { %>
    <div class="lcard"
         data-title="<%= listing.title.toLowerCase() %>"
         data-loc="<%= listing.location.toLowerCase() %> <%= listing.country.toLowerCase() %>"
         data-price="<%= listing.price %>">

      <!-- ── Image ── -->
      <a href="/listings/<%= listing._id %>" style="display:block;text-decoration:none;color:inherit">
        <div class="img-shell">
          <img src="<%= listing.image?.url %>" alt="<%= listing.title %>" loading="lazy">
          <div class="img-scrim"></div>

          <!-- top row -->
          <div class="img-tr">
            <% if (listing.isGuestFavorite) { %>
              <span class="guest-fav">★ Guest Favourite</span>
            <% } else { %>
              <span></span>
            <% } %>

            <% if (currUser) { %>
<form class="fav-form ajax-fav-form"
      data-id="<%= listing._id %>">

<%
const isFav =
currUser &&
currUser.favorites &&
currUser.favorites.some(
f => f.toString() === listing._id.toString()
);
%>

<button
  type="button"
  class="fav-btn <%= isFav ? 'liked' : '' %>"
>
  <span class="heart-icon">
    <%= isFav ? "❤️" : "🤍" %>
  </span>
</button>

</form>
            <% } %>
          </div>

          <!-- Dynamic Weather Pricing -->
<div class="price-chip dynamic-price-chip">

  <% if(listing.weatherType === "Rain") { %>
    <span class="weather-icon">🌧️</span>
  <% } else if(listing.weatherType === "Clouds") { %>
    <span class="weather-icon">☁️</span>
  <% } else if(listing.weatherType === "Clear") { %>
    <span class="weather-icon">☀️</span>
  <% } else { %>
    <span class="weather-icon">🌍</span>
  <% } %>

  <div class="price-info">
    <span class="chip-amt">
      ₹<%= listing.dynamicPrice.toLocaleString('en-IN') %>
    </span>

    <span class="chip-per">/ night</span>

    <% if(listing.dynamicPrice > listing.price) { %>
      <span class="price-status surge">
        ↑ High Demand
      </span>

    <% } else if(listing.dynamicPrice < listing.price) { %>
      <span class="price-status discount">
        ↓ Weather Deal
      </span>

    <% } else { %>
      <span class="price-status normal">
        Standard Price
      </span>
    <% } %>
  </div>
</div>

          <!-- rating chip -->
          <div class="rating-chip">
            <span class="star-ic">★</span>
            <span><%= listing.avgRating || 'New' %></span>
          </div>
        </div>

        <!-- Dynamic Pricing Badge -->
<div class="dynamic-badge">
  <%= listing.priceTag %>
</div>



        <!-- ── Card body ── -->
        <div class="card-body">
          <div class="card-row-1">
            <div class="card-title"><%= listing.title %></div>
          </div>
          <div class="card-loc">
            <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
