<% layout("/layouts/boilerplate") %>

<link href="https://fonts.googleapis.com/css2?family=Circular+Std:wght@300;400;500;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;500;600;700;800&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

<style>
  :root {
    --bg:           #0d0d0d;
    --bg-nav:       rgba(13,13,13,0.95);
    --surface:      #161616;
    --surface-2:    #1c1c1c;
    --surface-3:    #222222;
    --hover:        #282828;
    --border:       rgba(255,255,255,0.06);
    --border-2:     rgba(255,255,255,0.10);
    --border-3:     rgba(255,255,255,0.16);
    --ink:          #f7f7f7;
    --ink-2:        #a8a8a8;
    --ink-3:        #585858;
    --rose:         #FF385C;
    --rose-2:       #FF1A44;
    --rose-glow:    rgba(255,56,92,0.20);
    --rose-soft:    rgba(255,56,92,0.10);
    --amber:        #FFB400;
    --amber-soft:   rgba(255,180,0,0.12);
    --green:        #00C16E;
    --radius-card:  18px;
    --radius-btn:   12px;
    --radius-pill:  100px;
    --font:         'Figtree', -apple-system, sans-serif;
    --font-serif:   'Instrument Serif', Georgia, serif;
    --ease-out:     cubic-bezier(0.16, 1, 0.3, 1);
    --ease-spring:  cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--ink);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     STICKY SEARCH NAVBAR
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .top-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-nav);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 14px 32px;
  }

  .nav-inner {
    max-width: 1320px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .nav-logo {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--rose);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: -0.3px;
  }

  /* Search capsule */
  .search-capsule {
    flex: 1;
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    background: var(--surface-2);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-pill);
    padding: 5px 5px 5px 18px;
    gap: 10px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .search-capsule:focus-within {
    border-color: var(--border-3);
    box-shadow: 0 0 0 4px var(--rose-soft);
  }

  .search-capsule svg { color: var(--ink-3); flex-shrink: 0; }

  .search-capsule input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font);
    font-size: 13.5px;
    font-weight: 500;
    color: var(--ink);
    min-width: 0;
  }

  .search-capsule input::placeholder { color: var(--ink-3); font-weight: 400; }

  .search-exec {
    background: var(--rose);
    color: #fff;
    border: none;
    border-radius: var(--radius-pill);
    width: 38px;
    height: 38px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.18s, transform 0.15s var(--ease-spring);
  }

  .search-exec:hover { background: var(--rose-2); transform: scale(1.08); }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     CATEGORY PILL RAIL
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .cat-rail {
    background: var(--bg-nav);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .cat-rail::-webkit-scrollbar { display: none; }

  .cat-rail-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    gap: 4px;
    align-items: stretch;
  }

  .cat-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    padding: 14px 16px 12px;
    border-bottom: 2px solid transparent;
    color: var(--ink-3);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    cursor: pointer;
    flex-shrink: 0;
    transition: color 0.2s, border-color 0.2s;
    user-select: none;
  }

  .cat-pill .ci {
    font-size: 24px;
    line-height: 1;
    transition: transform 0.25s var(--ease-spring);
  }

  .cat-pill:hover { color: var(--ink-2); }
  .cat-pill:hover .ci { transform: translateY(-3px) scale(1.1); }
  .cat-pill.on { color: var(--ink); border-color: var(--rose); }
  .cat-pill.on .ci { transform: scale(1.15); }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     HERO BANNER
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .hero-banner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 52px 32px 0;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .hero-copy {}

  .hero-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero-eyebrow::after { content: ''; flex: 1; height: 1px; background: var(--rose); opacity: 0.3; max-width: 40px; }

  .hero-h1 {
    font-family: var(--font-serif);
    font-size: clamp(36px, 4.5vw, 60px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.5px;
    color: var(--ink);
  }

  .hero-h1 em { font-style: italic; color: var(--amber); }

  .hero-sub {
    margin-top: 10px;
    font-size: 15px;
    color: var(--ink-2);
    font-weight: 400;
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  /* sort pill */
  .sort-pill {
    display: flex;
    align-items: center;
    gap: 7px;
    background: var(--surface-2);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-pill);
    padding: 9px 16px;
    font-family: var(--font);
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-2);
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s, color 0.2s;
    color-scheme: dark;
  }

  .sort-pill:focus, .sort-pill:hover { border-color: var(--border-3); color: var(--ink); }

  /* view btns */
  .view-btns {
    display: flex;
    background: var(--surface-2);
    border: 1px solid var(--border-2);
    border-radius: 10px;
    overflow: hidden;
  }

  .vb {
    background: none;
    border: none;
    color: var(--ink-3);
    cursor: pointer;
    padding: 9px 14px;
    display: flex;
    align-items: center;
    transition: background 0.15s, color 0.15s;
  }

  .vb:hover { background: var(--hover); color: var(--ink-2); }
  .vb.on { background: var(--surface-3); color: var(--ink); }
  .vb + .vb { border-left: 1px solid var(--border); }

  .result-tag {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-3);
    margin-top: 6px;
  }

  .result-tag strong { color: var(--ink-2); font-weight: 600; }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     LISTING GRID
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .listing-grid {
    max-width: 1320px;
    margin: 0 auto;
    padding: 32px 32px 100px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(296px, 1fr));
    gap: 28px 18px;
  }

  .listing-grid.list-view {
    grid-template-columns: 1fr;
    gap: 14px;
  }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     CARD
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .lcard {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition:
      transform 0.35s var(--ease-out),
      box-shadow 0.35s var(--ease-out),
      border-color 0.25s;
    animation: rise 0.5s var(--ease-out) both;
    cursor: pointer;
  }

  .lcard:hover {
    transform: translateY(-5px);
    box-shadow:
      0 12px 40px rgba(0,0,0,0.45),
      0 0 0 1px rgba(255,255,255,0.07);
    border-color: var(--border-2);
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .lcard:nth-child(1) { animation-delay: .04s }
  .lcard:nth-child(2) { animation-delay: .08s }
  .lcard:nth-child(3) { animation-delay: .12s }
  .lcard:nth-child(4) { animation-delay: .16s }
  .lcard:nth-child(5) { animation-delay: .20s }
  .lcard:nth-child(6) { animation-delay: .24s }
  .lcard:nth-child(7) { animation-delay: .28s }
  .lcard:nth-child(8) { animation-delay: .32s }
  .lcard:nth-child(9) { animation-delay: .36s }
  .lcard:nth-child(10){ animation-delay: .40s }
  .lcard:nth-child(11){ animation-delay: .44s }
  .lcard:nth-child(12){ animation-delay: .48s }

  /* ── Image shell ── */
  .img-shell {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
    background: var(--surface-2);
    flex-shrink: 0;
  }

  .img-shell img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease-out), filter 0.4s;
    filter: brightness(0.85) saturate(1.1);
  }

  .lcard:hover .img-shell img {
    transform: scale(1.08);
    filter: brightness(1) saturate(1.15);
  }

  /* Scrim */
  .img-scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, rgba(13,13,13,0.6) 0%, transparent 55%),
      linear-gradient(to bottom, rgba(13,13,13,0.25) 0%, transparent 40%);
    pointer-events: none;
  }

  /* Top row on image */
  .img-tr {
    position: absolute;
    top: 12px; left: 12px; right: 12px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    z-index: 4;
  }

  .guest-fav {
    background: rgba(13,13,13,0.65);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,180,0,0.3);
    color: var(--amber);
    font-size: 9.5px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 6px;
  }

  .fav-btn {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(13,13,13,0.55);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.18);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s var(--ease-spring), background 0.2s;
    pointer-events: all;
  }

  .fav-btn:hover { transform: scale(1.15); background: rgba(13,13,13,0.8); }
  .fav-btn.liked svg path { fill: var(--rose); stroke: var(--rose); }

  /* Price chip */
  .price-chip {
    position: absolute;
    bottom: 14px; left: 14px;
    background: rgba(13,13,13,0.7);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    padding: 6px 12px;
    display: flex;
    align-items: baseline;
    gap: 3px;
    z-index: 4;
    pointer-events: none;
  }

  .chip-amt {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.3px;
  }

  .chip-per {
    font-size: 11px;
    color: rgba(255,255,255,0.5);
    font-weight: 400;
  }

  /* Rating chip */
  .rating-chip {
    position: absolute;
    bottom: 14px; right: 14px;
    background: rgba(13,13,13,0.7);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 5px 10px;
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    font-weight: 700;
    color: #fff;
    z-index: 4;
    pointer-events: none;
  }

  .rating-chip .star-ic { color: var(--amber); font-size: 10px; }

  /* ── Card body ── */
  .card-body {
    padding: 16px 18px 0;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-row-1 {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 3px;
  }

  .card-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.3;
    letter-spacing: -0.1px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  .card-loc {
    font-size: 12.5px;
    color: var(--ink-3);
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 12px;
  }

  .card-loc svg { flex-shrink: 0; }

  /* Feature pills */
  .feat-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }

  .feat {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    background: var(--surface-3);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-2);
    white-space: nowrap;
  }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     BOOK NOW BUTTON — THE STAR
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .book-now-form { padding: 14px 18px 18px; margin-top: auto; }

  .book-now-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 13px 20px;
    background: linear-gradient(135deg, #FF385C 0%, #FF1A44 100%);
    color: #fff;
    font-family: var(--font);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.01em;
    border: none;
    border-radius: var(--radius-btn);
    cursor: pointer;
    text-decoration: none;
    overflow: hidden;
    transition:
      transform 0.22s var(--ease-spring),
      box-shadow 0.22s,
      filter 0.18s;
    box-shadow:
      0 4px 18px var(--rose-glow),
      inset 0 1px 0 rgba(255,255,255,0.18);
  }

  /* shimmer layer */
  .book-now-btn::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
    transition: left 0.5s ease;
    pointer-events: none;
  }

  .book-now-btn:hover::before { left: 160%; }

  /* top gloss */
  .book-now-btn::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 50%;
    background: linear-gradient(to bottom, rgba(255,255,255,0.12) 0%, transparent 100%);
    pointer-events: none;
    border-radius: var(--radius-btn) var(--radius-btn) 0 0;
  }

  .book-now-btn:hover {
    transform: translateY(-2px) scale(1.015);
    box-shadow:
      0 8px 30px rgba(255,56,92,0.38),
      inset 0 1px 0 rgba(255,255,255,0.2);
    filter: brightness(1.06);
  }

  .book-now-btn:active {
    transform: scale(0.97);
    box-shadow: 0 3px 12px var(--rose-glow);
  }

  .btn-icon {
    width: 20px; height: 20px;
    background: rgba(255,255,255,0.2);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 11px;
  }

  .btn-label { position: relative; z-index: 1; }
  .btn-arrow { position: relative; z-index: 1; font-size: 16px; margin-left: 2px; opacity: 0.85; transition: transform 0.2s; }
  .book-now-btn:hover .btn-arrow { transform: translateX(3px); }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     LIST VIEW CARD
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .listing-grid.list-view .lcard {
    flex-direction: row;
    min-height: 160px;
  }

  .listing-grid.list-view .img-shell {
    width: 220px;
    min-width: 220px;
    aspect-ratio: unset;
    border-radius: 0;
  }

  .listing-grid.list-view .card-body {
    flex: 1;
    min-width: 0;
    padding: 18px 20px;
    flex-direction: row;
    align-items: center;
    gap: 20px;
  }

  .listing-grid.list-view .card-main { flex: 1; min-width: 0; }
  .listing-grid.list-view .card-row-1 { margin-bottom: 4px; }
  .listing-grid.list-view .feat-row { margin-bottom: 0; }
  .listing-grid.list-view .card-loc { margin-bottom: 8px; }

  .listing-grid.list-view .book-now-form {
    padding: 0;
    margin-top: 0;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    margin-left: auto;
  }

  .listing-grid.list-view .book-now-btn {
    width: auto;
    padding: 11px 22px;
    white-space: nowrap;
  }

  .listing-grid.list-view .lv-price {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--ink);
    font-weight: 400;
    text-align: right;
  }

  .listing-grid.list-view .lv-price small {
    font-size: 12px;
    color: var(--ink-3);
    font-family: var(--font);
    font-weight: 400;
    display: block;
    margin-top: 1px;
  }

  .listing-grid.list-view .price-chip,
  .listing-grid.list-view .rating-chip { display: none; }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     EMPTY STATE
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .empty {
    grid-column: 1/-1;
    text-align: center;
    padding: 120px 24px;
    animation: rise 0.5s var(--ease-out) both;
  }

