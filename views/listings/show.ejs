<% layout("/layouts/boilerplate") %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,700&family=Outfit:wght@200;300;400;500;600&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:          #060504;
    --bg-1:        #0C0A08;
    --bg-2:        #131109;
    --bg-3:        #1C1A14;
    --bg-4:        #26231A;
    --bg-5:        #312E22;

    --border:      rgba(255,255,255,0.05);
    --border-2:    rgba(255,255,255,0.09);
    --border-3:    rgba(255,255,255,0.14);

    --text-1:      #F0EAD8;
    --text-2:      #A8A090;
    --text-3:      #5C5848;
    --text-4:      #3A3728;

    --gold:        #C8A456;
    --gold-lt:     #E4C47A;
    --gold-dk:     #7A5E24;
    --gold-dim:    rgba(200,164,86,0.12);
    --gold-glow:   rgba(200,164,86,0.18);
    --gold-border: rgba(200,164,86,0.22);

    --amber:       #C97840;
    --ember:       rgba(201,120,64,0.08);

    --danger:      #B84032;
    --danger-dim:  rgba(184,64,50,0.08);

    --serif:       'Playfair Display', Georgia, serif;
    --sans:        'Outfit', system-ui, sans-serif;

    --ease-out:    cubic-bezier(0.16, 1, 0.3, 1);
    --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
    --ease-slow:   cubic-bezier(0.4, 0, 0.2, 1);
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text-1);
    font-family: var(--sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 20% -10%, rgba(200,164,86,0.05) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 110%, rgba(201,120,64,0.04) 0%, transparent 55%);
    pointer-events: none;
    z-index: 0;
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  .lp {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 32px 140px;
    position: relative;
    z-index: 1;
  }

  /* ─── HEADER ─── */
  .lp-header {
    padding: 56px 0 40px;
    margin-bottom: 44px;
    border-bottom: 1px solid var(--border);
    animation: fadeUp 0.8s var(--ease-out) both;
    position: relative;
  }

  .lp-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    opacity: 0.9;
  }

  .lp-eyebrow::before {
    content: '';
    display: inline-block;
    width: 32px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold));
  }
  .lp-eyebrow::after {
    content: '';
    display: inline-block;
    width: 32px;
    height: 1px;
    background: linear-gradient(90deg, var(--gold), transparent);
  }

  .lp-title {
    font-family: var(--serif);
    font-size: clamp(34px, 5vw, 62px);
    font-weight: 700;
    font-style: italic;
    line-height: 1.08;
    letter-spacing: -0.5px;
    color: var(--text-1);
    margin-bottom: 24px;
    max-width: 820px;
    background: linear-gradient(135deg, #F0EAD8 30%, #C8A456 80%, #F0EAD8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .lp-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    font-size: 13px;
    color: var(--text-2);
    font-weight: 300;
  }

  .lp-meta .sep {
    color: var(--border-3);
    font-size: 18px;
    line-height: 1;
  }

  .rating-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--gold-dim);
    border: 1px solid var(--gold-border);
    color: var(--gold-lt);
    padding: 5px 13px 5px 9px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.3px;
    transition: background 0.2s;
  }

  .rating-badge:hover { background: rgba(200,164,86,0.2); }

  .lp-location {
    color: var(--text-2);
    font-weight: 300;
    border-bottom: 1px solid var(--text-4);
    padding-bottom: 1px;
    transition: border-color 0.2s, color 0.2s;
    cursor: default;
  }
  .lp-location:hover { color: var(--text-1); border-color: var(--text-3); }

  /* ─── HERO ─── */
  .lp-hero {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 16/6.8;
    margin-bottom: 80px;
    background: var(--bg-3);
    animation: fadeUp 0.9s 0.1s var(--ease-out) both;
    box-shadow:
      0 0 0 1px var(--border),
      0 2px 0 rgba(255,255,255,0.03),
      0 40px 120px -24px rgba(0,0,0,0.9),
      0 0 80px -24px rgba(200,164,86,0.07);
  }

  .lp-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 10s var(--ease-out), filter 0.5s;
    filter: brightness(0.82) saturate(0.85) contrast(1.05);
  }

  .lp-hero:hover img {
    transform: scale(1.04);
    filter: brightness(0.88) saturate(1.0) contrast(1.02);
  }

  .lp-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(6,5,4,0.15) 0%,
      transparent 35%,
      rgba(6,5,4,0.62) 100%
    );
    pointer-events: none;
  }

  .lp-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 120px rgba(6,5,4,0.5);
    border-radius: 10px;
    pointer-events: none;
  }

  .lp-hero::before {
    content: '';
    position: absolute;
    top: 16px;
    left: 16px;
    right: 16px;
    bottom: 16px;
    border: 1px solid rgba(200,164,86,0.08);
    border-radius: 6px;
    pointer-events: none;
    z-index: 2;
  }

  /* ─── WEATHER BOX ─── */
  .weather-box {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    background: var(--bg-3);
    border: 1px solid var(--gold-border);
    border-radius: 8px;
    padding: 16px 24px;
    margin-bottom: 72px;
    position: relative;
    overflow: hidden;
    animation: fadeUp 0.9s 0.15s var(--ease-out) both;
  }

  .weather-box::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-dk), var(--gold), var(--gold-dk), transparent);
    opacity: 0.6;
  }

  .weather-box h4 {
    font-family: var(--serif);
    font-size: 14px;
    font-weight: 500;
    font-style: italic;
    color: var(--gold-lt);
    white-space: nowrap;
  }

  .weather-box p {
    font-size: 12.5px;
    color: var(--text-2);
    font-weight: 300;
  }

  .weather-box p strong { color: var(--text-1); font-weight: 500; }

  .weather-box img {
    width: 40px;
    height: 40px;
    filter: drop-shadow(0 0 8px rgba(200,164,86,0.3));
  }

  .weather-box h3 {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 600;
    color: var(--gold-lt);
    white-space: nowrap;
    border-left: 1px solid var(--border-3);
    padding-left: 20px;
  }

  /* ─── BODY GRID ─── */
  .lp-body {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 80px;
    align-items: start;
    animation: fadeUp 1s 0.2s var(--ease-out) both;
  }

  @media (max-width: 1000px) {
    .lp-body { grid-template-columns: 1fr; gap: 48px; }
    .lp-aside { order: -1; }
  }

  .lp-description {
    font-size: 15.5px;
    line-height: 1.9;
    color: var(--text-2);
    font-weight: 300;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 56px;
    letter-spacing: 0.1px;
  }

  /* ─── SECTION HEADER ─── */
  .section-head {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 36px;
  }

  .section-head h3 {
    font-family: var(--serif);
    font-size: 30px;
    font-weight: 400;
    font-style: italic;
    color: var(--text-1);
    display: flex;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
  }

  .section-tag {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--text-3);
    border: 1px solid var(--border-2);
    padding: 5px 14px;
    border-radius: 100px;
    white-space: nowrap;
    transition: border-color 0.2s, color 0.2s;
  }

  /* ─── REVIEWS GRID ─── */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
    gap: 14px;
    margin-bottom: 52px;
  }

  .rc {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 26px;
    position: relative;
    overflow: hidden;
    transition:
      border-color 0.35s,
      box-shadow 0.35s,
      transform 0.35s var(--ease-out),
      background 0.35s;
  }

  .rc::before {
    content: '\201C';
    font-family: var(--serif);
    font-size: 100px;
    line-height: 0.8;
    color: rgba(200,164,86,0.04);
    position: absolute;
    top: 12px;
    right: 12px;
    pointer-events: none;
    font-style: italic;
    transition: color 0.35s;
  }

  .rc::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.35s;
  }

  .rc:hover {
    border-color: rgba(200,164,86,0.18);
    box-shadow:
      0 20px 60px -12px rgba(0,0,0,0.7),
      0 0 0 1px rgba(200,164,86,0.08),
      inset 0 0 30px rgba(200,164,86,0.02);
    transform: translateY(-5px);
    background: var(--bg-3);
  }

  .rc:hover::before { color: rgba(200,164,86,0.07); }
  .rc:hover::after  { opacity: 0.6; }

  .rc-top {
    display: flex;
    align-items: center;
    gap: 13px;
    margin-bottom: 18px;
  }

  .rc-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold-dk) 0%, var(--gold) 50%, var(--gold-lt) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
    font-weight: 700;
    color: var(--bg);
    flex-shrink: 0;
    font-family: var(--serif);
    font-style: italic;
    box-shadow: 0 0 0 2px var(--bg-2), 0 0 0 4px rgba(200,164,86,0.15);
    transition: box-shadow 0.3s;
  }

  .rc:hover .rc-avatar {
    box-shadow: 0 0 0 2px var(--bg-3), 0 0 0 4px rgba(200,164,86,0.25), 0 0 20px rgba(200,164,86,0.15);
  }

  .rc-name {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--text-1);
    margin-bottom: 2px;
    letter-spacing: 0.1px;
  }

  .rc-date {
    font-size: 10.5px;
    color: var(--text-3);
    font-weight: 300;
    letter-spacing: 0.3px;
  }

  .rc-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 14px;
  }

  .rc-stars .s-on  {
    color: var(--gold);
    font-size: 12px;
    text-shadow: 0 0 6px rgba(200,164,86,0.4);
  }
  .rc-stars .s-off { color: var(--bg-5); font-size: 12px; }

  .rc-comment {
    font-size: 13.5px;
    line-height: 1.75;
    color: var(--text-2);
    font-weight: 300;
    margin-bottom: 20px;
    letter-spacing: 0.1px;
  }

  .rc-delete {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: 1px solid var(--border-2);
    border-radius: 5px;
    color: var(--text-3);
    font-size: 10.5px;
    font-weight: 500;
    padding: 6px 13px;
    cursor: pointer;
    font-family: var(--sans);
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .rc-delete:hover {
    border-color: var(--danger);
    color: var(--danger);
    background: var(--danger-dim);
  }

  /* ─── EMPTY STATE ─── */
  .no-reviews {
    text-align: center;
    padding: 72px 32px;
    border: 1px dashed rgba(255,255,255,0.06);
    border-radius: 10px;
    margin-bottom: 52px;
    background: radial-gradient(ellipse at 50% 0%, rgba(200,164,86,0.03) 0%, transparent 60%),
                var(--bg-2);
    position: relative;
    overflow: hidden;
  }

  .no-reviews-glyph {
    font-family: var(--serif);
    font-size: 64px;
    font-style: italic;
    background: linear-gradient(180deg, var(--gold-dk), rgba(200,164,86,0.1));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 14px;
    line-height: 1;
  }

  .no-reviews p {
    font-size: 14px;
    color: var(--text-3);
    font-weight: 300;
    line-height: 1.8;
  }

  /* ─── DIVIDER ─── */
  .s-rule {
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 56px 0 48px;
  }

  .s-rule::before, .s-rule::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-2));
  }
  .s-rule::after { background: linear-gradient(90deg, var(--border-2), transparent); }

  .s-rule-icon {
    color: var(--gold);
    font-size: 13px;
    opacity: 0.5;
    flex-shrink: 0;
    letter-spacing: 4px;
  }

  /* ─── ADD REVIEW ─── */
  .add-review h3 {
    font-family: var(--serif);
    font-size: 28px;
    font-weight: 400;
    font-style: italic;
    color: var(--text-1);
    margin-bottom: 26px;
  }

  .form-shell {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 36px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .form-shell:focus-within {
    border-color: var(--gold-border);
    box-shadow: 0 0 0 1px rgba(200,164,86,0.06), 0 20px 60px -20px rgba(200,164,86,0.08);
  }

  .form-shell::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-dk), var(--gold), var(--gold-dk), transparent);
    opacity: 0.5;
  }

  .fg { margin-bottom: 28px; }

  .fl {
    display: block;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 14px;
    transition: color 0.2s;
  }

  .fg:focus-within .fl { color: var(--gold); opacity: 0.8; }

  /* Star picker */
  .star-pick {
    display: flex;
    gap: 4px;
    flex-direction: row-reverse;
    justify-content: flex-end;
  }

  .star-pick input[type="radio"] { display: none; }

  .star-pick label {
    font-size: 36px;
    cursor: pointer;
    color: var(--bg-5);
    transition:
      color 0.15s,
      transform 0.2s var(--ease-spring),
      text-shadow 0.2s;
    line-height: 1;
    user-select: none;
  }

  .star-pick input:checked ~ label,
  .star-pick label:hover,
  .star-pick label:hover ~ label {
    color: var(--gold);
    text-shadow: 0 0 16px rgba(200,164,86,0.5), 0 0 32px rgba(200,164,86,0.2);
  }

  .star-pick label:hover { transform: scale(1.15) translateY(-2px); }
  .star-pick label:active { transform: scale(0.88); }

  .f-textarea {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 15px 18px;
    font-size: 14px;
    font-family: var(--sans);
    font-weight: 300;
    color: var(--text-1);
    background: var(--bg-1);
    resize: vertical;
    min-height: 115px;
    transition:
      border-color 0.25s,
      box-shadow 0.25s,
      background 0.25s;
    outline: none;
    line-height: 1.75;
    letter-spacing: 0.1px;
  }

  .f-textarea::placeholder { color: var(--text-4); }

  .f-textarea:focus {
    border-color: rgba(200,164,86,0.35);
    box-shadow:
      0 0 0 3px rgba(200,164,86,0.07),
      0 0 24px -8px rgba(200,164,86,0.12);
    background: var(--bg-2);
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: linear-gradient(135deg, var(--gold-dk) 0%, var(--gold) 50%, var(--gold-lt) 100%);
    color: var(--bg);
    border: none;
    border-radius: 6px;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 16px 36px;
    cursor: pointer;
    font-family: var(--sans);
    transition:
      box-shadow 0.25s,
      transform 0.15s,
      filter 0.25s;
    box-shadow:
      0 4px 24px -4px rgba(200,164,86,0.35),
      0 1px 0 rgba(255,255,255,0.15) inset;
    position: relative;
    overflow: hidden;
  }

  .btn-submit::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transition: left 0.5s;
  }

  .btn-submit:hover::before { left: 100%; }

  .btn-submit:hover {
    box-shadow:
      0 8px 36px -4px rgba(200,164,86,0.5),
      0 1px 0 rgba(255,255,255,0.2) inset;
    filter: brightness(1.06);
  }

  .btn-submit:active { transform: scale(0.97); }

  .btn-submit .arrow { transition: transform 0.2s var(--ease-out); }
  .btn-submit:hover .arrow { transform: translateX(5px); }

  /* ─── CHARTS ─── */
  .charts-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-top: 60px;
  }

  @media (max-width: 620px) { .charts-row { grid-template-columns: 1fr; } }

  .chart-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 26px;
    transition: border-color 0.3s, box-shadow 0.3s;
    position: relative;
    overflow: hidden;
  }

  .chart-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 60px;
    background: linear-gradient(to top, var(--bg-2), transparent);
    pointer-events: none;
    z-index: 1;
    border-radius: 0 0 10px 10px;
  }

  .chart-card:hover {
    border-color: var(--border-2);
    box-shadow: 0 12px 40px -12px rgba(0,0,0,0.5);
  }

  .chart-card h5 {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 24px;
  }

  /* ─── PRICE CARD ─── */
  .lp-aside { position: sticky; top: 28px; }

  .price-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 36px 30px;
    position: relative;
    overflow: hidden;
    box-shadow:
      0 40px 100px -20px rgba(0,0,0,0.8),
      0 0 0 1px rgba(255,255,255,0.025),
      inset 0 1px 0 rgba(255,255,255,0.04);
    transition: box-shadow 0.4s;
  }

  .price-card:hover {
    box-shadow:
      0 40px 100px -20px rgba(0,0,0,0.85),
      0 0 0 1px rgba(200,164,86,0.08),
      0 0 50px -20px rgba(200,164,86,0.06),
      inset 0 1px 0 rgba(255,255,255,0.04);
  }

  .pc-gold-line {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--gold-dk) 20%, var(--gold) 50%, var(--gold-lt) 65%, var(--gold) 80%, var(--gold-dk) 90%, transparent 100%);
    margin: 0 -30px 32px;
    opacity: 0.7;
    position: relative;
    overflow: hidden;
  }

  .pc-gold-line::after {
    content: '';
    position: absolute;
    top: 0; left: -150%;
    width: 150%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
    animation: shimmer 3s 1.5s ease infinite;
  }

  @keyframes shimmer {
    0%   { left: -150%; }
    100% { left: 150%; }
  }

  .price-card::before {
    content: '';
    position: absolute;
    top: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 240px;
    height: 160px;
    background: radial-gradient(ellipse, rgba(200,164,86,0.06) 0%, transparent 70%);
    pointer-events: none;
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.5; }
  }

  .pc-price-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 30px;
    position: relative;
    z-index: 1;
  }

  .pc-amount {
    font-family: var(--serif);
    font-size: 40px;
    font-weight: 700;
    font-style: italic;
    background: linear-gradient(135deg, var(--text-1) 20%, var(--gold-lt) 80%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -1px;
  }

  .pc-night {
    font-size: 12.5px;
    color: var(--text-3);
    font-weight: 300;
    margin-left: 5px;
    -webkit-text-fill-color: var(--text-3);
  }

  .pc-rating {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12.5px;
    color: var(--text-2);
  }

  .pc-rating strong {
    color: var(--gold-lt);
    font-weight: 600;
    -webkit-text-fill-color: var(--gold-lt);
  }

  .pc-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0 0 26px;
    position: relative;
    z-index: 1;
  }

  .pc-details {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 30px;
    position: relative;
    z-index: 1;
  }

  .pc-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    font-size: 13px;
    gap: 12px;
  }

  .pc-label {
    color: var(--text-3);
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 9px;
    flex-shrink: 0;
  }

  .pc-value {
    color: var(--text-2);
    font-weight: 300;
    text-align: right;
    max-width: 200px;
    line-height: 1.5;
  }

  .reserve-btn {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, var(--gold-dk) 0%, var(--gold) 50%, var(--gold-lt) 100%);
    color: var(--bg);
    border: none;
    border-radius: 7px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 19px;
    cursor: pointer;
    font-family: var(--sans);
    text-align: center;
    text-decoration: none;
    transition:
      box-shadow 0.25s,
      letter-spacing 0.35s,
      filter 0.25s,
      transform 0.15s;
    box-shadow:
      0 4px 28px -4px rgba(200,164,86,0.4),
      0 1px 0 rgba(255,255,255,0.18) inset;
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  .reserve-btn::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
    transition: left 0.6s;
  }

  .reserve-btn:hover::before { left: 100%; }

  .reserve-btn:hover {
    box-shadow:
      0 8px 40px -4px rgba(200,164,86,0.55),
      0 1px 0 rgba(255,255,255,0.22) inset;
    letter-spacing: 3.8px;
    filter: brightness(1.06);
  }

  .reserve-btn:active { transform: scale(0.98); }

  .pc-note {
    text-align: center;
    font-size: 11px;
    color: var(--text-4);
    margin-top: 13px;
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.3px;
    position: relative;
    z-index: 1;
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--bg-4); border-radius: 2px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text-3); }

  @media (max-width: 640px) {
    .lp { padding: 0 20px 100px; }
    .form-shell { padding: 24px 20px; }
    .price-card { padding: 28px 22px; }
  }
</style>

<div class="lp">

  <header class="lp-header">
    <div class="lp-eyebrow"><%= listing.country %></div>
    <h1 class="lp-title"><%= listing.title %></h1>
    <div class="lp-meta">
      <% if (listing.reviews.length > 0) {
           let avg = listing.reviews.reduce((s, r) => s + r.rating, 0) / listing.reviews.length; %>
        <span class="rating-badge">
          <svg width="10" height="10" viewBox="0 0 14 14" fill="currentColor">
            <path d="M7 1l1.5 3.1 3.4.5-2.5 2.4.6 3.4L7 9l-3 1.6.6-3.4L2.1 4.6l3.4-.5z"/>
          </svg>
          <%= avg.toFixed(2) %>
        </span>
        <span class="sep">·</span>
        <span><%= listing.reviews.length %> review<%= listing.reviews.length !== 1 ? 's' : '' %></span>
        <span class="sep">·</span>
      <% } %>
      <span class="lp-location"><%= listing.location %>, <%= listing.country %></span>
    </div>
  </header>

  <div class="lp-hero">
    <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
    <div class="lp-hero-overlay"></div>
  </div>

  <div class="weather-box">
    <% if(weatherData){ %>
      <h4>🌤 Weather in <%= listing.location %></h4>
      <img src="https://openweathermap.org/img/wn/<%= weatherData.icon %>@2x.png" alt="">
      <div>
        <p>Temperature: <strong><%= weatherData.temp %>°C</strong></p>
        <p>Condition: <strong><%= weatherData.weather %></strong></p>
      </div>
      <h3>₹<%= dynamicPrice %>/night</h3>
    <% } %>
  </div>

  <div class="lp-body">
    <div class="lp-left">
      <p class="lp-description"><%= listing.description %></p>

      <section>
        <div class="section-head">
          <% if (listing.reviews.length > 0) {
               let avg = listing.reviews.reduce((s, r) => s + r.rating, 0) / listing.reviews.length; %>
            <h3>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="var(--gold)">
                <path d="M7 1l1.5 3.1 3.4.5-2.5 2.4.6 3.4L7 9l-3 1.6.6-3.4L2.1 4.6l3.4-.5z"/>
              </svg>
              <%= avg.toFixed(2) %> &middot; Reviews
            </h3>
            <span class="section-tag"><%= listing.reviews.length %> total</span>
          <% } else { %>
            <h3>Guest Reviews</h3>
          <% } %>
        </div>

        <% if (listing.reviews.length > 0) { %>
          <div class="reviews-grid">
            <% listing.reviews.forEach(review => { %>
              <div class="rc">
                <div class="rc-top">
                  <div class="rc-avatar"><%= (review.author?.username || 'G')[0].toUpperCase() %></div>
                  <div>
                    <p class="rc-name"><%= review.author?.username || "Guest" %></p>
                    <p class="rc-date"><%= review.createdAt?.toDateString() %></p>
                  </div>
                </div>
                <div class="rc-stars">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <span class="<%= i <= review.rating ? 's-on' : 's-off' %>">★</span>
                  <% } %>
                </div>
                <p class="rc-comment"><%= review.comment %></p>
                <% if (currUser && review.author && currUser._id.equals(review.author._id)) { %>
                  <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                        method="POST" style="margin:0;">
                    <button class="rc-delete" type="submit">
                      <svg width="10" height="10" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M6 2h4a1 1 0 0 1 1 1H5a1 1 0 0 1 1-1zm-3 2h10l-1 9H4L3 4zm3.5 2v5h1V6h-1zm3 0v5h1V6h-1z"/>
                      </svg>
                      Delete
                    </button>
                  </form>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="no-reviews">
            <div class="no-reviews-glyph">"</div>
            <p>No reviews yet.<br>Be the first to share your experience.</p>
          </div>
        <% } %>
      </section>

      <div class="s-rule"><span class="s-rule-icon">✦</span></div>

      <div class="add-review">
        <h3>Leave a Review</h3>
        <div class="form-shell">
          <form action="/listings/<%= listing._id %>/reviews" method="POST">
            <div class="fg">
              <label class="fl">Your Rating</label>
              <div class="star-pick" id="starPick">
                <% for (let i = 5; i >= 1; i--) { %>
                  <input type="radio" name="review[rating]" id="sp<%= i %>" value="<%= i %>" required>
                  <label for="sp<%= i %>" title="<%= i %> star<%= i !== 1 ? 's' : '' %>">★</label>
                <% } %>
              </div>
            </div>
            <div class="fg">
              <label class="fl" for="rc">Your Experience</label>
              <textarea
                class="f-textarea"
                id="rc"
                name="review[comment]"
                rows="4"
                placeholder="Share what made your stay memorable — the atmosphere, the details, the host…"
                required
              ></textarea>
            </div>
            <button class="btn-submit" type="submit">
              Publish Review
              <svg class="arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 8h14M9 2l6 6-6 6"/>
              </svg>
            </button>
          </form>
        </div>
      </div>

      <div class="charts-row">
        <div class="chart-card">
          <h5>Monthly Bookings</h5>
          <canvas id="bookingsChart"></canvas>
        </div>
        <div class="chart-card">
          <h5>Cancellation Trend</h5>
          <canvas id="cancelChart"></canvas>
        </div>
      </div>
    </div>

    <aside class="lp-aside">
      <div class="price-card">
        <div class="pc-gold-line"></div>
        <div class="pc-price-row">
          <div>
            <span class="pc-amount">₹<%= listing.price.toLocaleString('en-IN') %></span>
            <span class="pc-night">/ night</span>
          </div>
          <% if (listing.reviews.length > 0) {
               let avg = listing.reviews.reduce((s, r) => s + r.rating, 0) / listing.reviews.length; %>
            <div class="pc-rating">
              <svg width="11" height="11" viewBox="0 0 14 14" fill="var(--gold)">
                <path d="M7 1l1.5 3.1 3.4.5-2.5 2.4.6 3.4L7 9l-3 1.6.6-3.4L2.1 4.6l3.4-.5z"/>
              </svg>
              <strong><%= avg.toFixed(2) %></strong>
              <span>(<%= listing.reviews.length %>)</span>
            </div>
          <% } %>
        </div>
        <hr class="pc-divider">
        <div class="pc-details">
          <div class="pc-row">
            <span class="pc-label">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              Location
            </span>
            <span class="pc-value"><%= listing.location %>, <%= listing.country %></span>
          </div>
        </div>
        <a 
  href="/listings/<%= listing._id %>/bookings/new?price=<%= dynamicPrice || listing.price %>" 
  class="reserve-btn"
>
  Reserve for now ₹<%= (dynamicPrice || listing.price).toLocaleString('en-IN') %>
</a>
        <p class="pc-note">You won't be charged yet</p>
      </div>
    </aside>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  const monthlyData = <%- JSON.stringify(monthlyBookings || []) %>;
  const cancelData  = <%- JSON.stringify(cancellationTrend || []) %>;

  const sharedOpts = {
    plugins: { legend: { display: false } },
    scales: {
      x: {
        grid: { display: false },
        border: { color: 'rgba(255,255,255,0.04)' },
        ticks: { font: { family: "'Outfit', sans-serif", size: 10, weight: '300' }, color: '#5C5848' }
      },
      y: {
        grid: { color: 'rgba(255,255,255,0.03)', drawBorder: false },
        border: { color: 'rgba(255,255,255,0.04)', dash: [4, 4] },
        ticks: { font: { family: "'Outfit', sans-serif", size: 10, weight: '300' }, color: '#5C5848' }
      }
    },
    animation: { duration: 1000, easing: 'easeOutQuart' }
  };

  if (monthlyData.length > 0) {
    new Chart(document.getElementById("bookingsChart"), {
      type: "bar",
      data: {
        labels: monthlyData.map(d => months[d._id - 1]),
        datasets: [{
          data: monthlyData.map(d => d.count),
          backgroundColor: ctx => {
            const g = ctx.chart.ctx.createLinearGradient(0, 0, 0, 160);
            g.addColorStop(0, 'rgba(200,164,86,0.25)');
            g.addColorStop(1, 'rgba(200,164,86,0.04)');
            return g;
          },
          borderColor: 'rgba(200,164,86,0.55)',
          borderWidth: 1.5,
          borderRadius: 5,
          hoverBackgroundColor: 'rgba(200,164,86,0.35)',
          hoverBorderColor: 'rgba(228,196,122,0.8)'
        }]
      },
      options: sharedOpts
    });
  }

  if (cancelData.length > 0) {
    new Chart(document.getElementById("cancelChart"), {
      type: "line",
      data: {
        labels: cancelData.map(d => months[d._id - 1]),
        datasets: [{
          data: cancelData.map(d => d.total === 0 ? 0 : ((d.cancelled / d.total) * 100).toFixed(1)),
          borderColor: 'rgba(201,120,64,0.75)',
          backgroundColor: ctx => {
            const g = ctx.chart.ctx.createLinearGradient(0, 0, 0, 140);
            g.addColorStop(0, 'rgba(201,120,64,0.15)');
            g.addColorStop(1, 'rgba(201,120,64,0.01)');
            return g;
          },
          borderWidth: 1.5,
          pointBackgroundColor: '#C97840',
          pointBorderColor: 'rgba(201,120,64,0.3)',
          pointBorderWidth: 3,
          pointRadius: 3.5,
          pointHoverRadius: 5,
          tension: 0.45,
          fill: true
        }]
      },
      options: sharedOpts
    });
  }
</script>