<% layout("/layouts/boilerplate") %>

<style>
body {
  background-color: #0f0f0f;
}

.signup-container {
  max-width: 420px;
  margin: 60px auto;
}

.signup-card {
  background: #1a1a1a;
  padding: 36px 32px;
  border-radius: 20px;
  border: 0.5px solid #2e2e2e;
}

.signup-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6px;
}

.signup-logo-icon {
  width: 36px;
  height: 36px;
  background: #ff385c;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

.signup-title {
  font-size: 20px;
  font-weight: 500;
  color: #f5f5f5;
  text-align: center;
  margin: 0 0 4px;
}

.signup-sub {
  font-size: 13px;
  color: #888;
  text-align: center;
  margin: 0 0 26px;
}

.form-label {
  font-size: 12px;
  color: #aaa;
  letter-spacing: 0.02em;
}

.form-control {
  background: #111;
  border: 0.5px solid #2e2e2e;
  border-radius: 10px;
  padding: 11px 14px;
  font-size: 14px;
  color: #f0f0f0;
}

.form-control::placeholder {
  color: #555;
}

.form-control:focus {
  background: #111;
  border-color: #ff385c;
  color: #f0f0f0;
  box-shadow: none;
}

/* File input styled as a clickable row */
.form-control[type="file"] {
  color: #555;
  cursor: pointer;
}

.form-control[type="file"]::-webkit-file-upload-button {
  background: #2a2a2a;
  border: 0.5px solid #3a3a3a;
  border-radius: 8px;
  color: #aaa;
  padding: 4px 12px;
  font-size: 12px;
  cursor: pointer;
  margin-right: 10px;
}

.divider {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 18px 0;
}

.divider-line {
  flex: 1;
  height: 0.5px;
  background: #2e2e2e;
}

.divider-text {
  font-size: 12px;
  color: #555;
}

.btn-google {
  width: 100%;
  background: transparent;
  border: 0.5px solid #2e2e2e;
  border-radius: 12px;
  padding: 11px;
  font-size: 14px;
  color: #d0d0d0;
  margin-bottom: 12px;
  transition: background 0.15s;
}

.btn-google:hover {
  background: #222;
  color: #d0d0d0;
}

.btn-airbnb {
  background: #ff385c;
  color: white;
  border-radius: 12px;
  padding: 12px;
  font-weight: 500;
  border: none;
  width: 100%;
  font-size: 14px;
  transition: background 0.15s;
}

.btn-airbnb:hover {
  background: #e31c5f;
  color: white;
}

.signup-footer {
  text-align: center;
  margin-top: 20px;
  font-size: 13px;
  color: #666;
}

.signup-footer a {
  color: #ff385c;
  text-decoration: none;
}
</style>

<div class="signup-container">
  <div class="signup-card">

    <div class="signup-logo">
      <div class="signup-logo-icon">🏠</div>
    </div>

    <p class="signup-title">Join StayFinder</p>
    <p class="signup-sub">Create your account to start exploring</p>

    <form action="/signup" method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>

      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input name="username" id="username" type="text" class="form-control" placeholder="Choose a username" required />
      </div>

      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input name="email" id="email" type="email" class="form-control" placeholder="Enter your email" required />
      </div>

      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input name="password" id="password" type="password" class="form-control" placeholder="Create a password" required />
      </div>

      <div class="mb-3">
        <label for="avatar" class="form-label">Profile photo</label>
        <input type="file" name="avatar" id="avatar" class="form-control" />
      </div>

      <div class="divider">
        <div class="divider-line"></div>
        <span class="divider-text">or sign up with</span>
        <div class="divider-line"></div>
      </div>

      <a href="/auth/google" class="btn btn-google">
        <i class="fa-brands fa-google me-2"></i> Continue with Google
      </a>

      <button class="btn-airbnb">Create account</button>

    </form>

    <div class="signup-footer">
      Already have an account? <a href="/login">Sign in</a>
    </div>

  </div>
</div>