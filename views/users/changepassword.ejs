<% layout("/layouts/boilerplate") %>

<style>
:root {
  --bg: #000000;
  --card: #0a0a0a;
  --border: #222222;
  --text: #f0f0f0;
  --sub: #888888;
  --input-bg: #111111;
  --input-border: #2a2a2a;
  --input-focus: #444444;
  --label: #999999;
  --placeholder: #444444;
  --divider: #1a1a1a;
}

body { background: var(--bg); }

.pw-container { max-width: 460px; margin: 56px auto; padding: 0 1rem; }

.pw-card {
  background: var(--card);
  border: 0.5px solid var(--border);
  border-radius: 20px;
  padding: 32px;
}

.pw-title { font-size: 20px; font-weight: 500; color: var(--text); margin-bottom: 6px; }
.pw-sub   { font-size: 13px; color: var(--sub); margin-bottom: 28px; }

.field { margin-bottom: 18px; }

.field label {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: var(--label);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: 7px;
}

.input-wrap { position: relative; display: flex; align-items: center; }

.input-icon {
  position: absolute; left: 13px;
  display: flex; align-items: center; pointer-events: none;
}

.toggle-eye {
  position: absolute; right: 13px;
  display: flex; align-items: center;
  background: none; border: none; cursor: pointer; padding: 0;
}

.input-wrap input {
  width: 100%;
  padding: 11px 40px 11px 38px;
  background: var(--input-bg);
  border: 0.5px solid var(--input-border);
  border-radius: 10px;
  color: var(--text);
  font-size: 14px;
  outline: none;
  transition: border-color .15s, background .15s;
}
.input-wrap input::placeholder { color: var(--placeholder); }
.input-wrap input:hover  { border-color: #333333; }
.input-wrap input:focus  { border-color: var(--input-focus); background: #161616; }

/* Strength bar */
.strength-bar { display: flex; gap: 4px; margin-top: 8px; }
.strength-bar span {
  flex: 1; height: 3px; border-radius: 99px;
  background: #222222; transition: background .3s;
}
.strength-label { font-size: 11px; color: var(--sub); margin-top: 5px; }

.pw-divider { border: none; border-top: 0.5px solid var(--divider); margin: 24px 0; }

.btn-update {
  width: 100%; padding: 12px; border-radius: 10px;
  background: #f0f0f0; color: #000000;
  border: none; font-size: 14px; font-weight: 500;
  cursor: pointer; transition: background .15s;
}
.btn-update:hover { background: #ffffff; }

.btn-cancel {
  width: 100%; padding: 11px; border-radius: 10px;
  background: transparent; color: var(--sub);
  border: 0.5px solid var(--border); font-size: 14px;
  cursor: pointer; transition: .15s; margin-top: 10px;
  display: block; text-align: center; text-decoration: none;
}
.btn-cancel:hover { background: #111111; color: var(--text); }
</style>

<div class="pw-container">
  <div class="pw-card">

    <div class="pw-title">Change password</div>
    <div class="pw-sub">Keep your account secure with a strong password</div>

    <form method="POST" action="/change-password">

      <div class="field">
        <label>Current password</label>
        <div class="input-wrap">
          <span class="input-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </span>
          <input type="password" id="old-pw" name="oldPassword" placeholder="Enter current password" required>
          <button class="toggle-eye" type="button" onclick="togglePw('old-pw', this)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="field">
        <label>New password</label>
        <div class="input-wrap">
          <span class="input-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </span>
          <input type="password" id="new-pw" name="newPassword"
            placeholder="Enter new password" required
            oninput="checkStrength(this.value)">
          <button class="toggle-eye" type="button" onclick="togglePw('new-pw', this)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
        <div class="strength-bar">
          <span id="s1"></span><span id="s2"></span>
          <span id="s3"></span><span id="s4"></span>
        </div>
        <div class="strength-label" id="s-label">Enter a new password</div>
      </div>

      <hr class="pw-divider">
      <button type="submit" class="btn-update">Update password</button>
    </form>

    <a href="/profile" class="btn-cancel">Cancel</a>

  </div>
</div>

<script>
function togglePw(id, btn) {
  const inp = document.getElementById(id);
  const showing = inp.type === 'text';
  inp.type = showing ? 'password' : 'text';
  btn.querySelector('svg').style.stroke = showing ? '#555' : '#aaa';
}

function checkStrength(val) {
  let score = 0;
  if (val.length >= 8) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;

  const colors = ['#E24B4A', '#EF9F27', '#3B6D11', '#1D9E75'];
  const labels = ['Weak', 'Fair', 'Good', 'Strong'];

  ['s1','s2','s3','s4'].forEach((id, i) => {
    document.getElementById(id).style.background = i < score ? colors[score - 1] : '#222';
  });

  const label = document.getElementById('s-label');
  label.textContent = val.length === 0 ? 'Enter a new password' : (labels[score - 1] || 'Weak');
  label.style.color  = val.length === 0 ? '#888' : (colors[score - 1] || '#E24B4A');
}
</script>