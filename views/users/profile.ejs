<% layout("/layouts/boilerplate") %>

<style>
:root {
  --bg: #000000;
  --card: #0a0a0a;
  --card2: #111111;
  --border: #222222;
  --border-dash: #2a2a2a;
  --text: #f5f5f5;
  --sub: #888888;
  --hint: #444444;
  --badge-bg: #161616;
  --badge-text: #888888;
  --icon-bg: #161616;
  --upload-bg: #0d0d0d;
  --nav-hover: #141414;
  --divider: #1a1a1a;
  --accent: #FF385C;
  --accent-dim: #3a0d14;
  --icon-edit-bg: #12122a; --icon-edit: #818cf8;
  --icon-home-bg: #1e0d13; --icon-home: #fb7185;
  --icon-lock-bg: #0a1a10; --icon-lock: #4ade80;
}

[data-theme="light"] {
  --bg: #f5f5f5;
  --card: #ffffff;
  --card2: #f9f9f9;
  --border: #e5e5e5;
  --border-dash: #cccccc;
  --text: #111111;
  --sub: #717171;
  --hint: #bbbbbb;
  --badge-bg: #f3f3f3;
  --badge-text: #666666;
  --icon-bg: #f0f0f0;
  --upload-bg: #fafafa;
  --nav-hover: #f5f5f5;
  --divider: #ebebeb;
  --accent-dim: #fff0f2;
  --icon-edit-bg: #eef2ff; --icon-edit: #4f46e5;
  --icon-home-bg: #fff0f3; --icon-home: #e11d48;
  --icon-lock-bg: #f0fdf4; --icon-lock: #16a34a;
}

body { background: var(--bg); transition: background .2s; }

.profile-container { max-width: 520px; margin: 48px auto; padding: 0 1rem; }

.theme-toggle-row { display: flex; justify-content: flex-end; margin-bottom: 16px; }
.theme-btn {
  background: var(--badge-bg); border: 0.5px solid var(--border);
  border-radius: 99px; padding: 6px 14px; font-size: 12px;
  color: var(--sub); cursor: pointer; display: flex; align-items: center;
  gap: 6px; transition: .15s;
}
.theme-btn:hover { background: var(--nav-hover); color: var(--text); }

.profile-card {
  background: var(--card); border: 0.5px solid var(--border);
  border-radius: 20px; padding: 28px;
  transition: background .2s, border-color .2s;
}

.profile-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; }

.avatar-circle {
  width: 68px; height: 68px; border-radius: 50%;
  background: var(--accent); display: flex; align-items: center;
  justify-content: center; font-size: 24px; font-weight: 500;
  color: #fff; flex-shrink: 0; overflow: hidden;
  position: relative; border: 2px solid var(--border);
}
.avatar-circle img { width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; }

.user-name  { font-size: 17px; font-weight: 500; color: var(--text); margin-bottom: 3px; }
.user-email { font-size: 13px; color: var(--sub); margin-bottom: 8px; }
.user-badge {
  display: inline-block; font-size: 11px; padding: 3px 10px;
  border-radius: 99px; background: var(--badge-bg); color: var(--badge-text);
  border: 0.5px solid var(--border);
}

.upload-zone {
  display: flex; align-items: center; gap: 12px;
  border: 0.5px dashed var(--border-dash); border-radius: 12px;
  padding: 13px 15px; background: var(--upload-bg); cursor: pointer; transition: .15s;
}
.upload-zone:hover { background: var(--nav-hover); }
.upload-icon-wrap {
  width: 34px; height: 34px; border-radius: 50%;
  background: var(--icon-bg); display: flex; align-items: center;
  justify-content: center; flex-shrink: 0;
}
.upload-title { font-size: 13px; font-weight: 500; color: var(--text); display: block; margin-bottom: 2px; }
.upload-hint  { font-size: 11px; color: var(--sub); }
.btn-choose {
  font-size: 12px; padding: 5px 12px; border-radius: 8px;
  border: 0.5px solid var(--border); background: var(--card2);
  color: var(--text); cursor: pointer; white-space: nowrap; flex-shrink: 0; transition: .15s;
}
.btn-choose:hover { background: var(--nav-hover); }

.profile-divider { border: none; border-top: 0.5px solid var(--divider); margin: 20px 0; }

.profile-nav { display: flex; flex-direction: column; gap: 4px; margin-bottom: 20px; }
.nav-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 11px 13px; border-radius: 12px; text-decoration: none;
  border: 0.5px solid transparent; transition: .15s;
}
.nav-item:hover { background: var(--nav-hover); border-color: var(--border); }
.nav-left  { display: flex; align-items: center; gap: 12px; }
.nav-icon  { width: 34px; height: 34px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.nav-label { font-size: 14px; color: var(--text); }
.chevron   { color: var(--hint); font-size: 18px; }

.btn-logout {
  width: 100%; padding: 11px; border-radius: 12px;
  border: 0.5px solid var(--border); background: var(--card2);
  color: var(--sub); font-size: 14px; font-weight: 500;
  cursor: pointer; display: flex; align-items: center;
  justify-content: center; gap: 8px; transition: .15s;
}
.btn-logout:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
</style>

<div class="profile-container">

  <div class="theme-toggle-row">
    <button class="theme-btn" id="theme-btn" onclick="toggleTheme()">
      ☀️ Light mode
    </button>
  </div>

  <div class="profile-card">

    <div class="profile-header">
      <div class="avatar-circle">
        <% if (user.avatar?.url) { %>
          <img src="<%= user.avatar.url %>" alt="avatar">
        <% } else { %>
          <%= user.username.charAt(0).toUpperCase() %>
        <% } %>
      </div>
      <div>
        <div class="user-name"><%= user.username %></div>
        <div class="user-email"><%= user.email %></div>
        <span class="user-badge">Member</span>
      </div>
    </div>

    <form action="/profile/avatar" method="POST" enctype="multipart/form-data">
      <label class="upload-zone">
        <div class="upload-icon-wrap">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--sub)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
        </div>
        <div style="flex:1">
          <span class="upload-title">Update profile photo</span>
          <span class="upload-hint">PNG or JPG, max 5MB</span>
        </div>
        <input type="file" name="avatar" required style="display:none" onchange="this.closest('form').submit()">
        <span class="btn-choose">Choose file</span>
      </label>
    </form>

    <hr class="profile-divider">

    <div class="profile-nav">
      <a href="/profile/edit" class="nav-item">
        <div class="nav-left">
          <div class="nav-icon" style="background:var(--icon-edit-bg)">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--icon-edit)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </div>
          <span class="nav-label">Edit profile</span>
        </div>
        <span class="chevron">›</span>
      </a>

      <a href="/mylistings" class="nav-item">
        <div class="nav-left">
          <div class="nav-icon" style="background:var(--icon-home-bg)">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--icon-home)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <span class="nav-label">My listings</span>
        </div>
        <span class="chevron">›</span>
      </a>

      <a href="/change-password" class="nav-item">
        <div class="nav-left">
          <div class="nav-icon" style="background:var(--icon-lock-bg)">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--icon-lock)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <span class="nav-label">Change password</span>
        </div>
        <span class="chevron">›</span>
      </a>
    </div>

    <a href="/logout" style="text-decoration:none">
      <button class="btn-logout">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        Logout
      </button>
    </a>

  </div>
</div>

<script>
  const btn = document.getElementById('theme-btn');
  let light = false;

  function toggleTheme() {
    light = !light;
    document.documentElement.setAttribute('data-theme', light ? 'light' : 'dark');
    localStorage.setItem('theme', light ? 'light' : 'dark');
    btn.textContent = light ? '🌑 Dark mode' : '☀️ Light mode';
  }

  const saved = localStorage.getItem('theme');
  if (saved === 'light') { light = true; document.documentElement.setAttribute('data-theme', 'light'); btn.textContent = '🌑 Dark mode'; }
</script>