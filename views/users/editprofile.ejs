<% layout("/layouts/boilerplate") %>

<style>
:root {
  --bg: #000000;
  --card: #0a0a0a;
  --border: #222222;
  --text: #f0f0f0;
  --sub: #888888;
  --input-bg: #111111;
  --input-border: #2a2a2a;
  --input-focus: #444444;
  --label: #999999;
  --placeholder: #444444;
  --btn: #f0f0f0;
  --btn-text: #000000;
  --btn-hover: #ffffff;
  --divider: #1a1a1a;
}

body { background: var(--bg); }

.edit-container { max-width: 460px; margin: 56px auto; padding: 0 1rem; }

.edit-card {
  background: var(--card);
  border: 0.5px solid var(--border);
  border-radius: 20px;
  padding: 32px;
}

.edit-title { font-size: 20px; font-weight: 500; color: var(--text); margin-bottom: 6px; }
.edit-sub   { font-size: 13px; color: var(--sub); margin-bottom: 28px; }

.field { margin-bottom: 20px; }

.field label {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: var(--label);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: 7px;
}

.input-wrap { position: relative; display: flex; align-items: center; }

.input-icon {
  position: absolute;
  left: 13px;
  display: flex;
  align-items: center;
  pointer-events: none;
}

.input-wrap input {
  width: 100%;
  padding: 11px 14px 11px 38px;
  background: var(--input-bg);
  border: 0.5px solid var(--input-border);
  border-radius: 10px;
  color: var(--text);
  font-size: 14px;
  outline: none;
  transition: border-color .15s, background .15s;
}

.input-wrap input::placeholder { color: var(--placeholder); }
.input-wrap input:hover  { border-color: #333333; }
.input-wrap input:focus  { border-color: var(--input-focus); background: #161616; }

.field-hint { font-size: 11px; color: var(--sub); margin-top: 5px; }

.edit-divider { border: none; border-top: 0.5px solid var(--divider); margin: 24px 0; }

.btn-save {
  width: 100%; padding: 12px; border-radius: 10px;
  background: var(--btn); color: var(--btn-text);
  border: none; font-size: 14px; font-weight: 500;
  cursor: pointer; transition: background .15s;
}
.btn-save:hover { background: var(--btn-hover); }

.btn-cancel {
  width: 100%; padding: 11px; border-radius: 10px;
  background: transparent; color: var(--sub);
  border: 0.5px solid var(--border); font-size: 14px;
  cursor: pointer; transition: .15s; margin-top: 10px;
  text-align: center; display: block; text-decoration: none;
}
.btn-cancel:hover { background: #111111; color: var(--text); }
</style>

<div class="edit-container">
  <div class="edit-card">

    <div class="edit-title">Edit profile</div>
    <div class="edit-sub">Update your username or email address</div>

    <form method="POST" action="/profile?_method=PUT">

      <div class="field">
        <label>Username</label>
        <div class="input-wrap">
          <span class="input-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </span>
          <input type="text" name="username" value="<%= user.username %>" placeholder="Enter username" required>
        </div>
      </div>

      <div class="field">
        <label>Email address</label>
        <div class="input-wrap">
          <span class="input-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </span>
          <input type="email" name="email" value="<%= user.email %>" placeholder="Enter email" required>
        </div>
        <div class="field-hint">We'll never share your email with anyone.</div>
      </div>

      <hr class="edit-divider">

      <button type="submit" class="btn-save">Save changes</button>
    <form method="POST" action="/profile?_method=PUT" enctype="multipart/form-data">

  <div class="field">
    <label>Profile Picture</label>
    <input type="file" name="avatar">
  </div>

  <!-- existing fields -->
</form>

    <a href="/profile" class="btn-cancel">Cancel</a>

  </div>
</div>